# -------------------------- 核心模型：单分支音频RNN --------------------------
class DeepSoundBaseRNN:
    def __init__(self,
         batch_size: int = 8,
         n_epochs: int = 100000,
         input_size: int = 1800,
         set_sample_weights: bool = True,
         feature_scaling: bool = False,
         output_size: int = 3,
         loss_type: str = 'focal'):  # 新增参数：默认focal，保持向后兼容
        # 新增：提前初始化关键属性，避免未定义错误
        self.target_encoder = None  # 关键修复：初始化target_encoder
        self.padding_class = None   # 之前已添加，保留
        self.class_weights = {}     # 关键修复：初始化class_weights
        # 新增1：根据loss_type创建对应损失函数
        self.loss_type = loss_type  # 记录loss_type，供后续判断使用
        if loss_type == 'focal':
            self.loss_fn = ClassBalancedFocalLoss(
                gamma_init=getattr(self, 'gamma_init', 1.5),  # 优先用子类参数
                gamma_max=getattr(self, 'gamma_max', 3),
                early_stop_patience=50
            )
            # 绑定target_encoder（后续从Experiment传递）
            self.loss_fn.target_encoder = None

        elif loss_type == 'ce':
            # 【论文创新点】中位数类别平衡加权交叉熵损失
            # 适配音频帧级分类，解决类别不平衡，温和加权不爆炸
            class WeightedCEWithLog(tf.keras.losses.Loss):
                def __init__(self, padding_class=None, class_weights=None, target_encoder=None, reduction=tf.keras.losses.Reduction.NONE):
                    super().__init__(reduction=reduction)
                    self.padding_class = padding_class
                    self.class_weights = class_weights or {}
                    self.target_encoder = target_encoder
                    self._printed = False  # 权重仅打印一次

                # 【核心：论文版中位数平衡权重】
                def set_class_counts(self, class_counts, target_encoder):
                    self.target_encoder = target_encoder
                    self.class_weights = {}
                    # 计算所有类别样本数的中位数（论文核心公式）
                    count_list = list(class_counts.values())
                    median_count = np.median(count_list)

                    # 为每个类别计算温和权重
                    for cls_idx, cnt in class_counts.items():
                        try:
                            cls_name = target_encoder.inverse_transform([cls_idx])[0]
                        except:
                            cls_name = f"class_{cls_idx}"

                        # 权重规则：背景类固定1，目标类中位数逆频加权+上限裁剪
                        if cls_name == 'no-event':
                            weight = 1.0
                        else:
                            weight = median_count / cnt
                            weight = min(weight, 3.0)  # 防止权重爆炸，音频任务专用

                        self.class_weights[cls_idx] = weight

                def call(self, y_true, y_pred, sample_weight=None):
                    # 非主GPU：纯计算，无日志
                    def non_main_gpu_logic():
                        ce = tf.keras.losses.sparse_categorical_crossentropy(y_true, y_pred, from_logits=True)
                        valid_mask = tf.cast(tf.not_equal(y_true, self.padding_class), tf.float32)

                        # 应用类别平衡权重
                        if self.class_weights:
                            weight_tensor = tf.convert_to_tensor(list(self.class_weights.values()), dtype=tf.float32)
                            cls_weight = tf.gather(weight_tensor, tf.cast(y_true, tf.int32))
                            ce = ce * cls_weight

                        if sample_weight is not None:
                            ce = ce * tf.cast(sample_weight, tf.float32)
                        return ce * valid_mask

                    # 主GPU：打印权重+计算损失
                    def main_gpu_logic():
                        if not self._printed:
                            tf.print("\n【论文版】中位数类别平衡CE权重：", output_stream=sys.stderr)
                            for cls_idx, w in self.class_weights.items():
                                try:
                                    cls_name = self.target_encoder.inverse_transform([cls_idx])[0]
                                except:
                                    cls_name = f"class_{cls_idx}"
                                tf.print(f"  {cls_name:18s} → {w:.4f}", output_stream=sys.stderr)
                            self._printed = True
                        ce = tf.keras.losses.sparse_categorical_crossentropy(y_true, y_pred, from_logits=True)
                        valid_mask = tf.cast(tf.not_equal(y_true, self.padding_class), tf.float32)
                        
                        # 应用类别平衡权重
                        if self.class_weights:
                            weight_tensor = tf.convert_to_tensor(list(self.class_weights.values()), dtype=tf.float32)
                            cls_weight = tf.gather(weight_tensor, tf.cast(y_true, tf.int32))
                            ce = ce * cls_weight
                        if sample_weight is not None:
                            ce = ce * tf.cast(sample_weight, tf.float32)
                        return ce * valid_mask

                    # 多GPU兼容逻辑
                    if tf.distribute.get_replica_context() is not None:
                        replica_id = tf.distribute.get_replica_context().replica_id_in_sync_group
                        is_non_main_gpu = tf.not_equal(replica_id, 0)
                        loss = tf.cond(is_non_main_gpu, non_main_gpu_logic, main_gpu_logic)
                    else:
                        loss = main_gpu_logic()

                    return loss

            self.loss_fn = WeightedCEWithLog(
                padding_class=None,
                class_weights=self.class_weights,
                target_encoder=self.target_encoder
            )
        # 👇 新增：4方案加权CE，保留原有ce完全不动
        elif loss_type == 'ce_weighted':
            self.loss_fn = CEWeightedCrossEntropy(
                padding_class=None,
                class_weights=self.class_weights,
                target_encoder=self.target_encoder
            )
            


        elif loss_type == 'ce_smooth':
            # 带【有监督全局自适应时序平滑】的CE损失（不分类别，统一平滑）
            class WeightedCEWithTemporalSmooth(tf.keras.losses.Loss):
                def __init__(self, padding_class=None, class_weights=None, target_encoder=None, reduction=tf.keras.losses.Reduction.NONE):
                    super().__init__(reduction=reduction)
                    self.padding_class = padding_class
                    self.class_weights = class_weights or {}
                    self.target_encoder = target_encoder
                    self._printed = False

                    # ✅ 音频任务最佳默认平滑值（你要的最佳配置）
                    self.max_smooth = 0.10  # 最大平滑
                    self.min_smooth = 0.02  # 最小平滑
                    self.current_epoch = tf.Variable(0, trainable=False)

                    # ✅ 补全训练循环需要的变量（修复核心报错！）
                    self.adaptive_weight = tf.Variable(0.0, trainable=False)
                    self.avg_confidence = tf.Variable(0.0, trainable=False)

                def set_class_counts(self, class_counts, target_encoder):
                    self.target_encoder = target_encoder
                    self.class_weights = {}
                    no_event_idx = None
                    no_event_count = 1
                    for idx, cnt in class_counts.items():
                        label_name = target_encoder.inverse_transform([idx])[0] if target_encoder else str(idx)
                        if label_name == 'no-event':
                            no_event_idx = idx
                            no_event_count = cnt
                            break
                    for idx, cnt in class_counts.items():
                        label_name = target_encoder.inverse_transform([idx])[0] if target_encoder else str(idx)
                        if label_name == 'no-event':
                            self.class_weights[idx] = 1.0
                        elif label_name in ['feeding-chew', 'rumination-chew']:
                            self.class_weights[idx] = no_event_count / cnt
                        else:
                            self.class_weights[idx] = 1.0

                # 🔥 核心：有监督全局自适应平滑权重
                def _get_adaptive_weight(self, y_true, y_pred):
                    valid_mask = tf.cast(tf.not_equal(y_true, self.padding_class), tf.float32)
                    prob = tf.nn.softmax(y_pred, axis=-1)
                    conf = tf.reduce_max(prob, axis=-1)
                    mean_conf = tf.reduce_sum(conf * valid_mask) / (tf.reduce_sum(valid_mask) + 1e-8)

                    # 计算自适应权重
                    w = self.max_smooth - (self.max_smooth - self.min_smooth) * mean_conf
                    w = tf.clip_by_value(w, self.min_smooth, self.max_smooth)

                    # ✅ 赋值给变量，供外部训练循环读取
                    self.adaptive_weight.assign(w)
                    self.avg_confidence.assign(mean_conf)
                    return w

                def call(self, y_true, y_pred, sample_weight=None):
                    # 原有CE逻辑
                    def non_main_gpu_logic():
                        ce = tf.keras.losses.sparse_categorical_crossentropy(y_true, y_pred, from_logits=True)
                        valid_mask = tf.cast(tf.not_equal(y_true, self.padding_class), tf.float32)
                        if sample_weight is not None:
                            ce = ce * tf.cast(sample_weight, tf.float32)
                        return ce * valid_mask
                    def main_gpu_logic():
                        if not self._printed:
                            tf.print("\n【CE+全局自适应平滑损失】", output_stream=sys.stderr)
                            tf.print(f"  平滑范围：{self.min_smooth} ~ {self.max_smooth}", output_stream=sys.stderr)
                            if self.class_weights and self.target_encoder is not None:
                                valid_cls = [idx for idx in self.class_weights.keys() if idx != self.padding_class]
                                for cls_idx in valid_cls:
                                    cls_name = self.target_encoder.inverse_transform([cls_idx])[0]
                                    tf.print(f"  {cls_name:15s} → {self.class_weights[cls_idx]:.4f}", output_stream=sys.stderr)
                            self._printed = True
                        ce = tf.keras.losses.sparse_categorical_crossentropy(y_true, y_pred, from_logits=True)
                        valid_mask = tf.cast(tf.not_equal(y_true, self.padding_class), tf.float32)
                        if sample_weight is not None:
                            ce = ce * tf.cast(sample_weight, tf.float32)
                        return ce * valid_mask
                    if tf.distribute.get_replica_context() is not None:
                        replica_id = tf.distribute.get_replica_context().replica_id_in_sync_group
                        is_non_main_gpu = tf.not_equal(replica_id, 0)
                        ce_loss = tf.cond(is_non_main_gpu, non_main_gpu_logic, main_gpu_logic)
                    else:
                        ce_loss = main_gpu_logic()

                    # 自适应时序平滑
                    valid_mask = tf.cast(tf.not_equal(y_true, self.padding_class), tf.float32)
                    y_pred_prob = tf.nn.softmax(y_pred, axis=-1)
                    prev = y_pred_prob[:, :-1, :]
                    next = y_pred_prob[:, 1:, :]
                    smooth_mask = tf.expand_dims(valid_mask[:, :-1] * valid_mask[:, 1:], axis=-1)
                    smooth_loss = tf.reduce_sum(tf.abs(prev - next) * smooth_mask) / (tf.reduce_sum(smooth_mask) + 1e-8)

                    # 计算总损失
                    adaptive_w = self._get_adaptive_weight(y_true, y_pred)
                    ce_avg = tf.reduce_sum(ce_loss) / (tf.reduce_sum(valid_mask) + 1e-8)
                    total_loss = ce_avg + adaptive_w * smooth_loss

                    # ❌ 删除内部epoch自增（和外部冲突）
                    # self.current_epoch.assign_add(1) 
                    return total_loss

            # 初始化损失函数
            self.loss_fn = WeightedCEWithTemporalSmooth(
                padding_class=None, 
                class_weights=self.class_weights, 
                target_encoder=None
            )
            
            
            
            
            
            
