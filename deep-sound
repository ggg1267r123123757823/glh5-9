class NaNDetector:
    """简易NaN/Inf检测器，替代原chewbite_fusion的NaNDetector"""
    def __init__(self, verbose: bool = True):
        self.verbose = verbose

    def check_nan(self, data, name: str = "data"):
        if isinstance(data, list):
            data = np.concatenate([np.array(d).ravel() for d in data if d is not None])
        elif isinstance(data, np.ndarray):
            data = data.ravel()
        else:
            return

        has_nan = np.isnan(data).any()
        has_inf = np.isinf(data).any()
        if self.verbose:
            if has_nan:
                print(f"⚠️ {name} 中检测到NaN值")
            if has_inf:
                print(f"⚠️ {name} 中检测到Inf值")
            if not has_nan and not has_inf:
                print(f"✅ {name} 无NaN/Inf值")

    def log_process(self, msg: str):
        if self.verbose:
            print(f"📝 {msg}")
def flatten_nested_data(data: Union[List, np.ndarray], target_level: int = 1) -> Union[List, np.ndarray]:
    """
    展平嵌套数据至目标层级（target_level=1表示样本级一维列表/数组）
    Args:
        data: 待处理数据（列表/数组）
        target_level: 目标嵌套层级，1为样本级一维结构
    Returns:
        展平后的数据，确保每个元素是单个样本的张量/数组
    """
    if isinstance(data, np.ndarray):
        # 数组直接返回（数组嵌套可通过shape判断样本数）
        return data
    
    current_level = 0
    temp_data = data
    # 逐层检查并展平，直到达到目标层级或无嵌套
    while current_level < target_level:
        if len(temp_data) == 0:
            break
        if isinstance(temp_data[0], (list, np.ndarray)):
            # 展平一层
            if isinstance(temp_data, list):
                new_temp = []
                for item in temp_data:
                    new_temp.extend(item) if isinstance(item, list) else new_temp.append(item)
                temp_data = new_temp
            current_level += 1
        else:
            break
    return temp_data
# -------------------------- 新增：简单内存计算工具 --------------------------
def get_obj_mem(obj):
    """算对象内存（字节），只处理numpy/tf/列表/字典"""
    if isinstance(obj, np.ndarray):
        return np.prod(obj.shape) * obj.dtype.itemsize
    elif isinstance(obj, (tf.Tensor, tf.Variable)):
        return obj.shape.num_elements() * obj.dtype.itemsize if obj.shape.num_elements() else 0
    elif isinstance(obj, (dict, list)):
        return sum(get_obj_mem(v) for v in (obj.values() if isinstance(obj, dict) else obj))
    return 0

def get_allreduce_mem():
    """算AllReduce通信缓存内存（GB）"""
    try:
        from tensorflow.python.distribute import collective_util
        return len(collective_util._collective_cache) * 0.0001  # 每个缓存约0.1MB
    except:
        return 0.0

def get_gru_mem(model):
    """算GRU隐藏状态内存（GB）"""
    total = 0.0
    for layer in model.layers:
        if isinstance(layer, tf.keras.layers.Bidirectional) and isinstance(layer.layer, tf.keras.layers.GRU):
            if hasattr(layer.layer, 'states'):
                total += sum(get_obj_mem(s) for s in layer.layer.states) / (1024**3)
    return total

def get_pad_mem(model_instance):
    """算填充样本内存（GB），仅统计音频填充数据"""
    pads = [model_instance.train_audio_pad, model_instance.val_audio_pad]
    return sum(get_obj_mem(p) for p in pads if p is not None) / (1024**3)

def get_graph_mem():
    """算TF图碎片内存（GB）"""
    from tensorflow.python.framework import ops
    graph = ops.get_default_graph()
    return max(0, len(graph.get_operations()) - 1000) * 0.00002  # 每个碎片约0.02MB

