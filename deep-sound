                        valid_labels = label_seq[valid_mask]
                        val_original_fe += np.sum(valid_labels == fe_idx)
                        val_original_ru += np.sum(valid_labels == ru_idx)
                        val_original_noevent += np.sum(valid_labels == noevent_idx)
