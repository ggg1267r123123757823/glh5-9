                    y_pred_idx = np.argmax(y_pred_proba)
                    y_pred_name = self.target_encoder.inverse_transform([y_pred_idx])[0] if y_pred_idx != self.padding_class else f"padding_class({self.padding_class})"

                    # 格式化输出（和训练集格式统一）
                    prob_str = ", ".join([f"{cls}: {p:.4f}" for cls, p in zip(class_names, y_pred_proba)])
                    log_msg = (
                        f"【验证集】全局第一个样本（索引0）- 窗口{win_idx:3d} | "
                        f"原始长度: {self.original_lengths[global_sample_idx]:3d} | "
                        f"原始类别: {y_true_name:15s} | "
                        f"预测类别: {y_pred_name:15s} | "
                        f"概率分布: {prob_str}"
                    )
                    self.win_logger.info(log_msg)

        # ✅ 【唯一修改】返回【总有效损失】，不再返回错误的平均loss
        return total_loss, avg_val_prec, avg_val_valid_precision, total_valid_count

