    def distributed_train_step(self, batch, batch_idx, current_epoch):  # 新增current_epoch参数
        model = self.model
        assert model is not None, "模型未初始化！"
        x, (y, sample_weights) = batch
        # 执行训练步骤，获取各GPU的TP/FP + 三类统计数值
        per_replica_result = self.strategy.run(
            self._train_step_static,
            args=(model, x, y, sample_weights, self.padding_class, self.train_total_valid_steps, self.target_encoder)
        )
        local_results = self.strategy.experimental_local_results(per_replica_result)
        # 汇总所有GPU的数值
        total_loss = 0.0
        total_tp = 0.0
        total_fp = 0.0
        total_fn = 0.0
        total_valid_tp = 0.0
        total_valid_fp = 0.0
        total_valid_count = 0.0
        # 本批三类统计
        batch_fe = 0
        batch_ru = 0
        batch_noevent = 0
        batch_total = 0
        for loss, tp, fp, fn, valid_tp, valid_fp, valid_count, fe, ru, noevent, total in local_results:
            total_loss += loss
            total_tp += tp
            total_fp += fp
            total_valid_tp += valid_tp
            total_valid_fp += valid_fp
            total_valid_count += valid_count
            # 汇总本批三类标签数
            batch_fe += fe.numpy() if isinstance(fe, tf.Tensor) else fe
            batch_ru += ru.numpy() if isinstance(ru, tf.Tensor) else ru
            batch_noevent += noevent.numpy() if isinstance(noevent, tf.Tensor) else noevent
            batch_total += total.numpy() if isinstance(total, tf.Tensor) else total
        # 更新全局指标
        self.train_prec_metric.true_positives.assign_add(total_tp)
        self.train_prec_metric.false_positives.assign_add(total_fp)
        # 新增：更新训练召回率
        total_fn += fn  # 新增：累计漏检FN

        # 修复：召回率用 total_fn，不是 total_fp
        self.train_recall_metric.true_positives.assign_add(total_tp)
        self.train_recall_metric.false_negatives.assign_add(total_fn) 
        self.valid_target_precision_metric.tp.assign_add(total_valid_tp)
        self.valid_target_precision_metric.fp.assign_add(total_valid_fp)
        # 累加至所有批总和
        self.train_all_fe += batch_fe
        self.train_all_ru += batch_ru
        self.train_all_noevent += batch_noevent
        self.train_all_total += batch_total
        self.train_batch_count += 1
        # 计算当前批次指标
        avg_prec = self.train_prec_metric.result()
        avg_valid_precision = self.valid_target_precision_metric.result()
        # 每批都输出（按批序号）
        # self.resource_logger.log(f"🔍 节点4-训练批（第{batch_idx+1}批）：")
        # self.resource_logger.log(f"  本批：总窗口数={int(batch_total)} | fe={int(batch_fe)} | ru={int(batch_ru)} | no-event={int(batch_noevent)} | 有效类TP={total_valid_tp}")
        # self.resource_logger.log(f"  累计：总窗口数={int(self.train_all_total)} | fe={int(self.train_all_fe)} | ru={int(self.train_all_ru)} | no-event={int(self.train_all_noevent)}")
        
        # 核心修复：返回4个变量，供fit方法解包
        return total_loss, avg_prec, avg_valid_precision, total_valid_count
        # 训练集窗口级输出（仅每10个Epoch输出，与验证集格式统一）
        if self.enable_win_log and self.win_logger and (current_epoch + 1) % 10 == 0:
            class_names = self.target_encoder.classes_
            local_y_train = self.strategy.experimental_local_results(y)[0] if len(self.strategy.experimental_local_results(y)) > 0 else y
            local_x_train = self.strategy.experimental_local_results(x)[0] if len(self.strategy.experimental_local_results(x)) > 0 else x
            initial_replica_batch = self.batch_size * self.strategy.num_replicas_in_sync
            for local_sample_idx in range(local_y_train.shape[0]):
                global_sample_idx = batch_idx * initial_replica_batch + local_sample_idx
                for win_idx in range(local_y_train.shape[1]):
                    y_true_idx = local_y_train[local_sample_idx, win_idx].numpy()
                    if hasattr(self, 'padding_class') and y_true_idx == self.padding_class:
                        continue
                    if y_true_idx not in [0, 1, 2]:
                        continue
                    y_true_name = self.target_encoder.inverse_transform([y_true_idx])[0]
                    local_pred_logits = self.model(local_x_train, training=True)
                    y_pred_proba = tf.nn.softmax(local_pred_logits[local_sample_idx, win_idx]).numpy()
                    if hasattr(self, 'padding_class') and self.padding_class < y_pred_proba.shape[-1]:
                        y_pred_proba[..., self.padding_class] = 0.0
                        valid_classes_mask = np.arange(y_pred_proba.shape[-1]) != self.padding_class
                        valid_sums = y_pred_proba[..., valid_classes_mask].sum(axis=-1, keepdims=True)
                        valid_sums = np.where(valid_sums == 0, 1.0, valid_sums)
                        y_pred_proba[..., valid_classes_mask] /= valid_sums
                    y_pred_idx = np.argmax(y_pred_proba)
                    y_pred_name = self.target_encoder.inverse_transform([y_pred_idx])[0] if y_pred_idx != self.padding_class else f"padding_class({self.padding_class})"

                    # 输出所有窗口（与验证集一致）
                    prob_str = ", ".join([f"{cls}: {p:.4f}" for cls, p in zip(class_names, y_pred_proba)])
                    log_msg = (
                        f"【训练集】全局样本{global_sample_idx:2d}（本地{local_sample_idx:2d}）- 窗口{win_idx:3d} | "
                        f"原始长度: {self.original_lengths[global_sample_idx]:3d} | "
                        f"原始类别: {y_true_name:15s} | "
                        f"预测类别: {y_pred_name:15s} | "
                        f"概率分布: {prob_str}"
                    )
                    self.win_logger.info(log_msg)

        

