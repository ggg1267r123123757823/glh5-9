    def reset_epoch_stats(self):
        """重置统计累加器（含no-event）"""
        self.current_epoch = 0
        # 原有两类统计重置
        self.epoch_feeding_total.assign(0)
        self.epoch_feeding_correct.assign(0)
        self.epoch_feeding_to_rum.assign(0)
        self.epoch_feeding_to_noevent.assign(0)
        self.epoch_rumination_total.assign(0)
        self.epoch_rumination_correct.assign(0)
        self.epoch_rumination_to_feed.assign(0)
        self.epoch_rumination_to_noevent.assign(0)
        # 新增no-event统计重置
        self.epoch_no_event_total.assign(0)
        self.epoch_no_event_correct.assign(0)
        self.epoch_no_event_to_feed.assign(0)
        self.epoch_no_event_to_rum.assign(0)
        self.current_batch = 0  # 保留原始普通变量

    def _calculate_batch_stats(self, y_true, y_pred_argmax, valid_mask):
        """计算批次误判数据（新增no-event统计）"""
        valid_mask = tf.cast(valid_mask, tf.bool)
        if len(valid_mask.shape) == 3:
            valid_mask = tf.squeeze(valid_mask, axis=-1)
        # 强制过滤padding_class（关键修复）
        if hasattr(self, 'padding_class'):
            valid_mask = tf.logical_and(valid_mask, tf.not_equal(y_true, self.padding_class))
        # 获取各类编码索引（按标签名直接获取，不依赖valid_indices）
        try:
            no_event_idx = list(self.target_encoder.classes_).index(self.no_event_class)
            feed_idx = list(self.target_encoder.classes_).index('feeding-chew')
            rum_idx = list(self.target_encoder.classes_).index('rumination-chew')
        except (ValueError, AttributeError) as e:
            self.logger.error(f"❌ 有效类索引获取失败：{e}")
            no_event_idx = 1
            feed_idx = 0
            rum_idx = 2

        # --- 原有两类统计（保持不变）---
        # feeding-chew统计
        feeding_true_mask = tf.logical_and(valid_mask, tf.equal(y_true, feed_idx))
        feeding_total = tf.reduce_sum(tf.cast(feeding_true_mask, tf.int32))
        feeding_correct = tf.reduce_sum(tf.cast(tf.logical_and(feeding_true_mask, tf.equal(y_pred_argmax, feed_idx)), tf.int32))
        feeding_to_rum = tf.reduce_sum(tf.cast(tf.logical_and(feeding_true_mask, tf.equal(y_pred_argmax, rum_idx)), tf.int32))
        feeding_to_noevent = tf.reduce_sum(tf.cast(tf.logical_and(feeding_true_mask, tf.equal(y_pred_argmax, no_event_idx)), tf.int32))
        # rumination-chew统计
        rum_true_mask = tf.logical_and(valid_mask, tf.equal(y_true, rum_idx))
        rum_total = tf.reduce_sum(tf.cast(rum_true_mask, tf.int32))
        rum_correct = tf.reduce_sum(tf.cast(tf.logical_and(rum_true_mask, tf.equal(y_pred_argmax, rum_idx)), tf.int32))
        rum_to_feed = tf.reduce_sum(tf.cast(tf.logical_and(rum_true_mask, tf.equal(y_pred_argmax, feed_idx)), tf.int32))
        rum_to_noevent = tf.reduce_sum(tf.cast(tf.logical_and(rum_true_mask, tf.equal(y_pred_argmax, no_event_idx)), tf.int32))

        # --- 新增no-event统计 ---
        no_event_true_mask = tf.logical_and(valid_mask, tf.equal(y_true, no_event_idx))
        no_event_total = tf.reduce_sum(tf.cast(no_event_true_mask, tf.int32))
        no_event_correct = tf.reduce_sum(tf.cast(tf.logical_and(no_event_true_mask, tf.equal(y_pred_argmax, no_event_idx)), tf.int32))
        no_event_to_feed = tf.reduce_sum(tf.cast(tf.logical_and(no_event_true_mask, tf.equal(y_pred_argmax, feed_idx)), tf.int32))
        no_event_to_rum = tf.reduce_sum(tf.cast(tf.logical_and(no_event_true_mask, tf.equal(y_pred_argmax, rum_idx)), tf.int32))

        return {
            'feeding': {'total': feeding_total, 'correct': feeding_correct, 'to_rum': feeding_to_rum, 'to_noevent': feeding_to_noevent},
            'rumination': {'total': rum_total, 'correct': rum_correct, 'to_feed': rum_to_feed, 'to_noevent': rum_to_noevent},
            'no_event': {'total': no_event_total, 'correct': no_event_correct, 'to_feed': no_event_to_feed, 'to_rum': no_event_to_rum}
        }

    def set_training_state(self, is_training):
        self.is_training = is_training

    def call(self, y_true, y_pred, sample_weight=None):
        """核心Loss计算+统计累加（含no-event输出）"""
        # 只保留类型转换，遇None直接抛出原错误
        y_true = tf.cast(y_true, tf.int32)
        # ========== 完全保留原始逻辑 ==========
        gamma = self.gamma_init + (self.gamma_max - self.gamma_init) * min(
            self.current_epoch_num / self.effective_max_epochs, 1.0
        )
        y_true_onehot = tf.one_hot(y_true, depth=y_pred.shape[-1])
        cross_entropy = tf.keras.losses.categorical_crossentropy(y_true_onehot, y_pred, from_logits=True)
        softmax_pred = tf.nn.softmax(y_pred, axis=-1)
        y_pred_argmax = tf.argmax(y_pred, axis=-1, output_type=tf.int32)
        # 加载类别权重
        class_weight_tensor = tf.convert_to_tensor(
            [self.class_weights.get(idx, 1.0) for idx in range(y_pred.shape[-1])],
            dtype=tf.float32
        )
        class_weight_tensor = tf.expand_dims(class_weight_tensor, axis=0)
        class_weight = tf.matmul(y_true_onehot, class_weight_tensor, transpose_b=True)
        class_weight = tf.squeeze(class_weight, axis=-1)
        # 有效样本掩码（过滤填充值）
        valid_mask = tf.not_equal(y_true, self.padding_class) if hasattr(self, 'padding_class') else tf.ones_like(y_true, dtype=tf.bool)
        valid_mask_float = tf.cast(valid_mask, tf.float32)
        if len(valid_mask_float.shape) == 3:
            valid_mask_float = tf.squeeze(valid_mask_float, axis=-1)
        # Focal调制因子
        valid_target_mask = tf.reduce_any(tf.equal(y_true[:, :, None], self.valid_indices), axis=-1)
        valid_target_mask = tf.cast(valid_target_mask, tf.float32)
        valid_target_mask = tf.expand_dims(valid_target_mask, axis=-1)
        p_t = tf.reduce_sum(y_true_onehot * softmax_pred, axis=-1, keepdims=True)
        p_t = tf.where(valid_target_mask == 1.0, p_t, tf.reduce_sum(y_true_onehot * softmax_pred, axis=-1, keepdims=True))
        modulating_factor = (1.0 - p_t) ** gamma
        modulating_factor = tf.squeeze(modulating_factor, axis=-1)
        # 最终Loss计算
        base_loss = cross_entropy * modulating_factor * class_weight
        if sample_weight is not None:
            sample_weight = tf.cast(sample_weight, tf.float32)
            base_loss = base_loss * sample_weight * valid_mask_float
        if self.current_batch == 1:
            y_true_flat = tf.reshape(y_true, [-1])
            # 固定编码对应：0=feeding-chew，1=no-event，2=rumination-chew（避免索引错误）
            fe_idx = tf.constant(0, dtype=tf.int32)
            noevent_idx = tf.constant(1, dtype=tf.int32)
            ru_idx = tf.constant(2, dtype=tf.int32)
            # TF安全求和，不依赖外部变量
            true_fe = tf.reduce_sum(tf.cast(tf.equal(y_true_flat, fe_idx), tf.int32))
            true_ru = tf.reduce_sum(tf.cast(tf.equal(y_true_flat, ru_idx), tf.int32))
            true_noevent = tf.reduce_sum(tf.cast(tf.equal(y_true_flat, noevent_idx), tf.int32))
            true_total = tf.shape(y_true_flat)[0]
            # 输出格式和节点1完全一致（去掉output_stream，确保日志可见）
            tf.print("🔍 节点5-统计前：")
            tf.print("  训练集：总窗口数=", true_total, " | fe=", true_fe, " | ru=", true_ru, " | no-event=", true_noevent)
        # 批次统计累加（含no-event）
        batch_stats = self._calculate_batch_stats(y_true, y_pred_argmax, valid_mask)
        # 原有两类累加
        self.epoch_feeding_total.assign_add(batch_stats['feeding']['total'])
        self.epoch_feeding_correct.assign_add(batch_stats['feeding']['correct'])
        self.epoch_feeding_to_rum.assign_add(batch_stats['feeding']['to_rum'])
        self.epoch_feeding_to_noevent.assign_add(batch_stats['feeding']['to_noevent'])
        self.epoch_rumination_total.assign_add(batch_stats['rumination']['total'])
        self.epoch_rumination_correct.assign_add(batch_stats['rumination']['correct'])
        self.epoch_rumination_to_feed.assign_add(batch_stats['rumination']['to_feed'])
        self.epoch_rumination_to_noevent.assign_add(batch_stats['rumination']['to_noevent'])
        # 新增no-event累加
        self.epoch_no_event_total.assign_add(batch_stats['no_event']['total'])
        self.epoch_no_event_correct.assign_add(batch_stats['no_event']['correct'])
        self.epoch_no_event_to_feed.assign_add(batch_stats['no_event']['to_feed'])
        self.epoch_no_event_to_rum.assign_add(batch_stats['no_event']['to_rum'])
        # 批次计数器累加
        self.current_batch += 1
        # Epoch结束输出汇总（新增no-event行）
        # 核心修改：仅训练时触发日志，验证时不触发
        if self.is_training and self.steps_per_epoch > 0 and self.current_batch == self.steps_per_epoch:
            # ========== 补充 safe_ratio 函数定义（关键修复） ==========
            def safe_ratio(numerator, denominator):
                return tf.math.divide_no_nan(
                    tf.cast(numerator, tf.float32), 
                    tf.cast(denominator, tf.float32)
                )
            # ==========================================================
            # 计算各类比例
            f_corr = safe_ratio(self.epoch_feeding_correct, self.epoch_feeding_total)
            f_to_rum = safe_ratio(self.epoch_feeding_to_rum, self.epoch_feeding_total)
            f_to_noe = safe_ratio(self.epoch_feeding_to_noevent, self.epoch_feeding_total)
            r_corr = safe_ratio(self.epoch_rumination_correct, self.epoch_rumination_total)
            r_to_feed = safe_ratio(self.epoch_rumination_to_feed, self.epoch_rumination_total)
            r_to_noe = safe_ratio(self.epoch_rumination_to_noevent, self.epoch_rumination_total)
            # 新增no-event比例
            n_corr = safe_ratio(self.epoch_no_event_correct, self.epoch_no_event_total)
            n_to_feed = safe_ratio(self.epoch_no_event_to_feed, self.epoch_no_event_total)
            n_to_rum = safe_ratio(self.epoch_no_event_to_rum, self.epoch_no_event_total)
            
            # 转换为Tensor避免打印异常
            feeding_total = tf.cast(self.epoch_feeding_total, tf.int32)
            rumination_total = tf.cast(self.epoch_rumination_total, tf.int32)
            no_event_total = tf.cast(self.epoch_no_event_total, tf.int32)
            gamma_tensor = tf.cast(gamma, tf.float32)
            
            self.logger.info(f"\n📌 Epoch {self.current_epoch_num} 误判比例汇总（权重：no-event=1，feeding≈5.38，rumination≈8.59）📌")
            # feeding-chew 输出
            tf.print(
                "├─ feeding-chew（总有效样本：", feeding_total, "）| 预测正确：",
                tf.round(tf.multiply(f_corr, 10000) / 100), "% | 误判为rumination：",
                tf.round(tf.multiply(f_to_rum, 10000) / 100), "% | 误判为no-event：",
                tf.round(tf.multiply(f_to_noe, 10000) / 100), "%",
                output_stream=sys.stderr
            )
            # rumination-chew 输出
            tf.print(
                "├─ rumination-chew（总有效样本：", rumination_total, "）| 预测正确：",
                tf.round(tf.multiply(r_corr, 10000) / 100), "% | 误判为feeding：",
                tf.round(tf.multiply(r_to_feed, 10000) / 100), "% | 误判为no-event：",
                tf.round(tf.multiply(r_to_noe, 10000) / 100), "%",
                output_stream=sys.stderr
            )
            # 新增no-event 输出
            tf.print(
                "├─ no-event（总有效样本：", no_event_total, "）| 预测正确：",
                tf.round(tf.multiply(n_corr, 10000) / 100), "% | 误判为feeding：",
                tf.round(tf.multiply(n_to_feed, 10000) / 100), "% | 误判为rumination：",
                tf.round(tf.multiply(n_to_rum, 10000) / 100), "%",
                output_stream=sys.stderr
            )
            # gamma值输出
            tf.print(
                "└─ 本轮gamma值：", tf.round(tf.multiply(gamma_tensor, 100) / 100), "（难样本惩罚强度）\n",
                output_stream=sys.stderr
            )
        
        return base_loss
