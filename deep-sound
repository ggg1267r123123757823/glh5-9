    # 单分支模型构建
    # 🔴 修改1：函数添加3个可优化参数（默认值不影响原有代码）
    def _build_model(self, max_seq_len: int, output_size: int = 3, dropout_rate=0.2, lr=0.001, weight_decay=1e-4) -> keras.Model:
        with tf.device('/GPU:0'):
            # 1. 音频输入层（单分支仅音频输入）
            audio_input = layers.Input(shape=(None, self.input_size, 1), name='audio_input', dtype='float32')

            # 2. 音频分支（复用你原有CNN+GRU结构）
            audio_branch = self._build_audio_branch()
            audio_features = audio_branch(audio_input)

            # 3. FFN子网络（复用原有结构）
            ffn = Sequential(name='ffn_subnetwork')
            ffn.add(layers.Dense(256, activation=activations.relu, kernel_initializer=GlorotUniform(),
                                 name='ffn_dense_1', dtype='float32'))
            # 🔴 修改2：固定dropout 0.2 → 改为优化参数
            ffn.add(layers.Dropout(rate=dropout_rate, name='ffn_dropout_1'))
            ffn.add(layers.Dense(128, activation=activations.relu, kernel_initializer=GlorotUniform(),
                                 name='ffn_dense_2', dtype='float32'))
            # 🔴 修改2：固定dropout 0.2 → 改为优化参数
            ffn.add(layers.Dropout(rate=dropout_rate, name='ffn_dropout_2'))
            ffn.add(layers.Dense(output_size, activation=None, name='ffn_output', dtype='float32'))
            outputs = layers.TimeDistributed(ffn, name='time_distributed_ffn')(audio_features)

            # 关键缺失代码：实例化Model对象（这一行之前漏了！）
            model = Model(inputs=audio_input, outputs=outputs, name='deep_sound_single_branch')

            # 4. 模型编译（原有逻辑保留）
            # 🔴 修改3：替换为AdamW + 优化学习率 + 权重衰减
            optimizer = tf.keras.optimizers.AdamW(
                learning_rate=lr,
                weight_decay=weight_decay
            )

            model.compile(
                optimizer=optimizer,
                loss=self.loss_fn,
                weighted_metrics=[
                    CustomSparseCategoricalPrecision(num_classes=output_size, name='precision'),
                    ValidTargetPrecision(
                        target_encoder=self.target_encoder,
                        valid_targets=['feeding-chew', 'rumination-chew', 'no-event'],
                        name='valid_target_precision',
                        class_weights=self.loss_fn.class_weights if hasattr(self.loss_fn, 'class_weights') else {}
                    )
                ]
            )
            # 绑定padding_class到指标（确保过滤填充值）
            for metric in model.metrics:
                if isinstance(metric, CustomSparseCategoricalPrecision):
                    metric.set_padding_class(self.padding_class)
                elif isinstance(metric, ValidTargetPrecision):
                    metric.padding_class = self.padding_class
            # 绑定padding_class到所有指标
            for metric in model.metrics:
                if hasattr(metric, 'set_padding_class'):
                    metric.set_padding_class(self.padding_class)
                elif hasattr(metric, 'padding_class'):
                    metric.padding_class = self.padding_class


            return model

    # 1. 修改 _train_step_static 方法
    @staticmethod
    @tf.function(experimental_relax_shapes=True, experimental_compile=False, autograph=False)
    def _train_step_static(model, inputs, labels, weights, padding_class, train_total_valid_steps, target_encoder):
        with tf.GradientTape() as tape:
            y_pred = model(inputs, training=True)
            # 调用自定义CE损失（已含权重应用）
            loss = model.loss(labels, y_pred, sample_weight=weights)
            
            valid_mask_bool = tf.not_equal(labels, tf.cast(padding_class, dtype=labels.dtype))
            valid_mask_float = tf.cast(valid_mask_bool, dtype=tf.float32)
            valid_loss = loss * valid_mask_float
            total_valid_loss = tf.reduce_sum(valid_loss)
            train_total_steps = tf.constant(train_total_valid_steps, dtype=tf.float32)
            train_total_steps = tf.maximum(train_total_steps, 1.0)
            real_valid_samples = tf.reduce_sum(valid_mask_float)
            avg_loss_per_step = total_valid_loss / tf.maximum(real_valid_samples, 1.0)
        # ✅ 【唯一修改】梯度用【总有效损失】计算（删除平均loss，修复核心错误）
        grads = tape.gradient(total_valid_loss, model.trainable_variables)
        grads = [tf.zeros_like(var) if grad is None else grad for grad, var in zip(grads, model.trainable_variables)]
        model.optimizer.apply_gradients(zip(grads, model.trainable_variables))
        # 核心修改：计算当前GPU分片的TP/FP + 三类标签统计（在replica上下文内）
        y_true_onehot = tf.one_hot(tf.cast(labels, tf.int32), depth=model.output_shape[-1])
        y_pred_argmax = tf.argmax(y_pred, axis=-1, output_type=tf.int32)
        y_pred_onehot = tf.one_hot(y_pred_argmax, depth=model.output_shape[-1])
        valid_mask_3d = tf.expand_dims(valid_mask_bool, axis=-1)
        valid_mask_3d = tf.cast(valid_mask_3d, tf.float32)
        tp = tf.reduce_sum(y_true_onehot * y_pred_onehot * valid_mask_3d, axis=[0, 1, 2])
        fp = tf.reduce_sum((1 - y_true_onehot) * y_pred_onehot * valid_mask_3d, axis=[0, 1, 2])
        # 新增：计算漏检 FN（真实为1，预测为0）
        fn = tf.reduce_sum(y_true_onehot * (1 - y_pred_onehot) * valid_mask_3d, axis=[0, 1, 2])
        tp = tf.maximum(tp, 0.0)
        fp = tf.maximum(fp, 0.0)
        # 计算有效目标（feeding/rumination）的TP/FP
        valid_indices = [list(target_encoder.classes_).index(lbl) for lbl in ['feeding-chew', 'rumination-chew']]
        valid_tp = 0.0
        valid_fp = 0.0
        for idx in valid_indices:
            true_mask = tf.logical_and(valid_mask_bool, tf.equal(labels, idx))
            pred_mask = tf.logical_and(valid_mask_bool, tf.equal(y_pred_argmax, idx))
            valid_tp += tf.reduce_sum(tf.cast(tf.logical_and(true_mask, pred_mask), tf.float32))
            valid_fp += tf.reduce_sum(tf.cast(tf.logical_and(tf.logical_not(true_mask), pred_mask), tf.float32))
        # 新增：三类标签统计（0=fe，1=no-event，2=ru）
        batch_fe = tf.reduce_sum(tf.cast(tf.logical_and(valid_mask_bool, tf.equal(labels, 0)), tf.int32))
        batch_ru = tf.reduce_sum(tf.cast(tf.logical_and(valid_mask_bool, tf.equal(labels, 2)), tf.int32))
        batch_noevent = tf.reduce_sum(tf.cast(tf.logical_and(valid_mask_bool, tf.equal(labels, 1)), tf.int32))
        batch_total = batch_fe + batch_ru + batch_noevent
        # ✅ 【唯一修改】返回【总有效损失】，不再返回平均loss
        return total_valid_loss, tp, fp, fn,valid_tp, valid_fp, tf.reduce_sum(valid_mask_float), batch_fe, batch_ru, batch_noevent, batch_total

