class PostTrainingMemoryValidator:
    """训练后内存验证类，统计不可释放对象占比"""
    def __init__(self, model_instance, memory_logger):
        self.model_instance = model_instance
        self.memory_logger = memory_logger
        self.process = psutil.Process(os.getpid())

    def _get_core_data_memory(self):
        """统计核心不可释放数据内存（仅音频）"""
        total = 0.0
        core_objs = [
            'train_audio', 'train_y', 'train_sample_weights',
            'val_audio', 'val_y', 'val_sample_weights'
        ]
        for obj_name in core_objs:
            obj = getattr(self.model_instance, obj_name, None)
            if isinstance(obj, np.ndarray):
                obj_mem = np.prod(obj.shape) * obj.dtype.itemsize / (1024**3)
                total += obj_mem
                self.memory_logger.log(f"🔒 核心不可释放-{obj_name}：{obj_mem:.2f} GB（下一轮要用）")
        return total

    def _get_releasable_memory(self):
        """统计可释放临时对象内存（仅音频）"""
        total = 0.0
        releasable_objs = [
            'train_audio_pad', 'train_y_pad', 'train_weight_pad',
            'val_audio_pad', 'val_y_pad', 'val_weight_pad'
        ]
        for obj_name in releasable_objs:
            obj = getattr(self.model_instance, obj_name, None)
            if isinstance(obj, np.ndarray):
                obj_mem = np.prod(obj.shape) * obj.dtype.itemsize / (1024**3)
                total += obj_mem
                self.memory_logger.log(f"✅ 临时可释放-{obj_name}：{obj_mem:.2f} GB")
        return total

    def validate(self, epoch=None):
        prefix = f"Epoch {epoch} 训练后" if epoch else "训练后"
        self.memory_logger.log(f"\n===== {prefix} 内存验证结果 =====")
        process_mem = self.process.memory_info().rss / (1024**3)
        self.memory_logger.log(f"📊 进程总内存：{process_mem:.2f} GB")

        core_mem = self._get_core_data_memory()
        releasable_mem = self._get_releasable_memory()
        non_releasable_ratio = (core_mem / process_mem) * 100 if process_mem > 0 else 0

        self.memory_logger.log(f"\n📌 不可释放核心数据占比：{non_releasable_ratio:.2f}%")
        self.memory_logger.log(f"📌 可释放临时对象占比：{100 - non_releasable_ratio:.2f}%")
        self.memory_logger.log("====================================================\n")

# -------------------------- 资源日志记录器 --------------------------
class ResourceLogger:
    """资源日志记录器，实时写入文件，增强内存峰值监控"""
    def __init__(self, log_file: Optional[str] = None):
        if log_file is None:
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            self.log_file = f"training_resource_log_{timestamp}.txt"
        else:
            self.log_file = log_file

        self.system_info: Dict = {}
        self.memory_peaks = {
            'preprocessing': {'cpu_memory_used': 0.0, 'gpu_memory_used': {}, 'process_memory_used': 0.0},
            'training': {'cpu_memory_used': 0.0, 'gpu_memory_used': {}, 'process_memory_used': 0.0},
            'callbacks': {'cpu_memory_used': 0.0, 'gpu_memory_used': {}, 'process_memory_used': 0.0},
            'overall': {'cpu_memory_used': 0.0, 'gpu_memory_used': {}, 'process_memory_used': 0.0}
        }
        self.initialized = False
        self.gpu_handles: List = []

        with open(self.log_file, 'w', encoding='utf-8') as f:
            f.write(f"===== 日志开始于: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')} =====\n")

        if pynvml_available:
            try:
                pynvml.nvmlInit()
                self.device_count = pynvml.nvmlDeviceGetCount()
                self.gpu_handles = [pynvml.nvmlDeviceGetHandleByIndex(i) for i in range(self.device_count)]
                self.initialized = True
                for phase in self.memory_peaks:
                    for i in range(self.device_count):
                        self.memory_peaks[phase]['gpu_memory_used'][i] = 0.0
            except pynvml.NVMLError as e:
                self.log(f"GPU监控初始化失败: {e}")

    def log(self, message: str, include_timestamp: bool = True) -> None:
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        entry = f"[{timestamp}] {message}" if include_timestamp else message
        with open(self.log_file, 'a', encoding='utf-8') as f:
            f.write(entry + "\n")
        print(message)

    def update_memory_peaks(self, phase: str, batch: Optional[int] = None, epoch: Optional[int] = None) -> None:
        if phase not in self.memory_peaks:
            raise ValueError(f"无效的阶段名称: {phase}，必须是以下之一: {list(self.memory_peaks.keys())}")

        mem = psutil.virtual_memory()
        current_used = mem.used / (1024**3)
        if current_used > self.memory_peaks[phase]['cpu_memory_used']:
            self.memory_peaks[phase]['cpu_memory_used'] = current_used
        if current_used > self.memory_peaks['overall']['cpu_memory_used']:
            self.memory_peaks['overall']['cpu_memory_used'] = current_used

        process = psutil.Process(os.getpid())
        current_process_used = process.memory_info().rss / (1024**3)
        if current_process_used > self.memory_peaks[phase]['process_memory_used']:
            self.memory_peaks[phase]['process_memory_used'] = current_process_used
        if current_process_used > self.memory_peaks['overall']['process_memory_used']:
            self.memory_peaks['overall']['process_memory_used'] = current_process_used

        if pynvml_available and self.initialized:
            for i, handle in enumerate(self.gpu_handles):
                try:
                    mem_info = pynvml.nvmlDeviceGetMemoryInfo(handle)
                    current_gpu_used = mem_info.used / (1024**3)
                    if current_gpu_used > self.memory_peaks[phase]['gpu_memory_used'][i]:
                        self.memory_peaks[phase]['gpu_memory_used'][i] = current_gpu_used
                    if current_gpu_used > self.memory_peaks['overall']['gpu_memory_used'][i]:
                        self.memory_peaks['overall']['gpu_memory_used'][i] = current_gpu_used
                except pynvml.NVMLError as e:
                    self.log(f"更新GPU {i} 内存峰值失败: {e}")

    def record_training_summary(self, training_info: Dict[str, str]) -> None:
        self.log("\n===== 训练总结 =====")
        for key, value in training_info.items():
            self.log(f"{key}: {value}")
        self.log("====================\n")

    def record_memory_summary(self) -> None:
        self.log("\n===== 内存使用总结 =====")
        mem = psutil.virtual_memory()
        total_mem_gb = mem.total / (1024**3)
        used_mem_gb = mem.used / (1024**3)
        available_mem_gb = mem.available / (1024**3)
        self.log(f"CPU内存状态:")
        self.log(f"  总内存: {total_mem_gb:.2f} GB")
        self.log(f"  已使用: {used_mem_gb:.2f} GB ({mem.percent}%)")
        self.log(f"  剩余可用: {available_mem_gb:.2f} GB")

        if pynvml_available and self.initialized:
            for i, handle in enumerate(self.gpu_handles):
                try:
                    mem_info = pynvml.nvmlDeviceGetMemoryInfo(handle)
                    used_vram_gb = mem_info.used / (1024**3)
                    total_vram_gb = mem_info.total / (1024**3)
                    available_vram_gb = mem_info.free / (1024**3)
                    gpu_name = pynvml.nvmlDeviceGetName(handle)
                    if isinstance(gpu_name, bytes):
                        gpu_name = gpu_name.decode('utf-8')
                except pynvml.NVMLError as e:
                    self.log(f"获取GPU {i} 内存信息失败: {e}")
        self.log("=======================\n")

    def save_log(self) -> None:
        self.log(f"\n日志已保存到: {os.path.abspath(self.log_file)}", include_timestamp=False)
        if pynvml_available and self.initialized:
            try:
                pynvml.nvmlShutdown()
            except:
                pass

