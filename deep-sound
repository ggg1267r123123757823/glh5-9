                    self.resource_logger.log(f"  fe截断后个数：{val_truncated_fe}")
                    self.resource_logger.log(f"  ru截断后个数：{val_truncated_ru}")
                    self.resource_logger.log(f"  no-event截断后个数：{val_truncated_noevent}")
                    self.resource_logger.log(f"  截断后总有效个数：{val_truncated_fe + val_truncated_ru + val_truncated_noevent}")
                    self.resource_logger.log(f"  截断丢失个数：fe={val_original_fe - val_truncated_fe} | ru={val_original_ru - val_truncated_ru} | no-event={val_original_noevent - val_truncated_noevent}")

                    if val_audio.ndim == 3:
                        val_audio = np.expand_dims(val_audio, axis=-1)
                    total_val_samples = val_audio.shape[0]  # 17个真实样本
                    # 修复val_y：append移到循环内，保留17个样本
                    val_y_padded = []
                    for label_seq in val_y:
                        label_seq = np.array(label_seq, dtype='int32')
                        seq_len = len(label_seq)
