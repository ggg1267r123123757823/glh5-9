class BehaviorGateDenoise(layers.Layer):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.judge = tf.keras.Sequential([
            layers.Dense(8, activation="relu"),
            layers.Dense(1, activation="sigmoid")
        ])

    def call(self, x):
        score = self.judge(x)

        # 真正合理的区间
        # <0.4   → 较像噪声 → 轻压到 0.7
        # 0.4~0.6 → 真·模棱两可 → 不压
        # >0.6   → 像信号 → 不压
        # weight = tf.where(score < 0.4, 0.7, 1.0)
        # weight = tf.where(score < 0.4, 0.6, 1.0)
        # weight = tf.where(score < 0.4, 0.68, 1.0)
        weight = tf.where(score < 0.4, 0.7, 1.0)

        return x * weight
