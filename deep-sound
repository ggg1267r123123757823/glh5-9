    # ===================== 【论文级真实可解释性热力图（Grad-CAM）】 =====================
    def plot_real_heatmap(self, raw_audio_path, target_class=0, save_dir=None):
        import matplotlib
        matplotlib.use('Agg')
        import matplotlib.pyplot as plt
        import librosa
        import numpy as np
        import tensorflow as tf
        import os
        import logging

        from chewbite_fusion.data.make_dataset import get_windows_from_audio_signal
        from chewbite_fusion.features.feature_factories import FeatureFactory_RawAudioData

        logger = logging.getLogger(__name__)

        # ===================== 【永久修复路径】严格按照你要的结构 =====================
        # 根目录：fold_1/heatmap_output/
        if hasattr(self, 'model_save_path'):
            # 模型所在的 fold_1 文件夹
            fold_dir = os.path.dirname(self.model_save_path)
        else:
            fold_dir = os.getcwd()
        # 核心：创建 heatmap_output 文件夹在 fold_1 下
        save_dir = os.path.join(fold_dir, "heatmap_output")
        # 每个音频独立子文件夹
        audio_name = os.path.splitext(os.path.basename(raw_audio_path))[0]
        audio_save_dir = os.path.join(save_dir, audio_name)
        os.makedirs(audio_save_dir, exist_ok=True)

        # 基础参数
        SR = 8000
        WINDOW_SEC = 0.1
        OVERLAP_RATIO = 0.5
        SLICE_SEC = 5
        SLICE_SAMPLES = SLICE_SEC * SR

        # 特征提取
        feature_factory = FeatureFactory_RawAudioData(
            audio_sampling_frequency=SR,
            movement_sampling_frequency=100
        )
        feature_extractor = feature_factory.features[0]
        feature_extractor.phase = 'test'

        # 加载音频
        try:
            y, _ = librosa.load(raw_audio_path, sr=SR)
        except:
            logger.error("音频加载失败")
            return

        total_samples = len(y)
        slice_num = total_samples // SLICE_SAMPLES
        if slice_num == 0:
            logger.error(f"音频{audio_name}不足5秒，跳过")
            return

        for i in range(slice_num):
            start = i * SLICE_SAMPLES
            end = start + SLICE_SAMPLES
            y_slice = y[start:end]

            # 窗口划分
            windows = get_windows_from_audio_signal(
                signal=y_slice,
                sampling_frequency=SR,
                window_width=WINDOW_SEC,
                window_overlap=OVERLAP_RATIO
            )

            # 特征提取（815维，无重复标准化）
            windows_list = [ [[win] for win in windows] ]
            features = feature_extractor.transform(windows_list)[0]
            features = np.array(features, dtype=np.float32)
            test_input = features[np.newaxis, ..., np.newaxis].astype(np.float32)
            test_input = tf.convert_to_tensor(test_input)

            # 注意力计算
            with tf.GradientTape() as tape:
                tape.watch(test_input)
                pred = self.model(test_input, training=False)
                score = pred[:, :, target_class] if len(pred.shape) == 3 else pred[:, target_class]

            grads = tape.gradient(score, test_input)
            attn = tf.reduce_mean(tf.abs(grads), axis=[0, 2, 3]).numpy()
            attn = (attn - attn.min()) / (attn.max() - attn.min() + 1e-8)

            # 生成梅尔频谱（用于2、3张图）
            mel = librosa.feature.melspectrogram(y=y_slice, sr=SR, n_mels=128, fmax=4000)
            mel_db = librosa.power_to_db(mel, ref=np.max)
            attn_resized = np.resize(attn, mel_db.shape[1])

            # ===================== 1. 缩小版 原始波形图 =====================
            plt.figure(figsize=(4.5, 1))  # 缩小尺寸
            librosa.display.waveshow(y_slice, sr=SR, color='#2c3e50')
            plt.axis('off')
            plt.tight_layout(pad=0)
            plt.savefig(os.path.join(audio_save_dir, f"{audio_name}_slice_{i+1}_1_wave.png"), dpi=300, bbox_inches='tight', pad_inches=0)
            plt.close()

            # ===================== 2. 缩小版 原始梅尔图 =====================
            plt.figure(figsize=(4.5, 1))  # 缩小尺寸
            librosa.display.specshow(mel_db, sr=SR, x_axis='time', y_axis='mel', cmap='viridis')
            plt.axis('off')
            plt.tight_layout(pad=0)
            plt.savefig(os.path.join(audio_save_dir, f"{audio_name}_slice_{i+1}_2_mel.png"), dpi=300, bbox_inches='tight', pad_inches=0)
            plt.close()

            # ===================== 3. 缩小版 强区分热力图 =====================
            plt.figure(figsize=(4.5, 1))  # 缩小尺寸
            librosa.display.specshow(mel_db, sr=SR, x_axis='time', y_axis='mel', cmap='viridis')
            # 配色改为hot，透明度降低，和梅尔彻底区分
            plt.imshow(attn_resized[np.newaxis, :], cmap='hot', alpha=0.25, extent=[0, 5, 0, 4000], aspect='auto')
            plt.axis('off')
            plt.tight_layout(pad=0)
            plt.savefig(os.path.join(audio_save_dir, f"{audio_name}_slice_{i+1}_3_mel_heatmap.png"), dpi=300, bbox_inches='tight', pad_inches=0)
            plt.close()

        logger.info(f"✅ 音频 {audio_name} 处理完成 | 保存路径：{audio_save_dir}")

# -------------------------- 模型子类（封装初始化参数） --------------------------
class DeepSound(DeepSoundBaseRNN):
    def __init__(self,
             batch_size: int = 5,
             input_size: int = 800,
             output_size: int = 4,
             n_epochs: int = 100000,
             training_reshape: bool = False,
             set_sample_weights: bool = True,
             feature_scaling: bool = False,
             loss_type: str = 'focal',
             learning_rate: float = 3e-4,  # 新增：学习率
             gamma_init: float = 1.5,     # 新增：Focal初始gamma
             gamma_max: float = 3.0):     # 新增：Focal最大gamma
        # 初始化填充变量
        self.train_audio_pad = None
        self.train_y_pad = None
        self.train_weight_pad = None
        self.val_audio_pad = None
        self.val_y_pad = None
        self.val_weight_pad = None
        # 保存新增参数到实例
        self.learning_rate = learning_rate
        self.gamma_init = gamma_init
        self.gamma_max = gamma_max
        # 调用父类初始化（传递loss_type）
        super().__init__(
            batch_size=batch_size,
            n_epochs=n_epochs,
            input_size=input_size,
            set_sample_weights=set_sample_weights,
            feature_scaling=feature_scaling,
            output_size=output_size,
            loss_type=loss_type
        )
        # 传递gamma参数给Focal损失（仅当loss_type为focal时）
        if loss_type == 'focal':
            self.loss_fn.gamma_init = gamma_init
            self.loss_fn.gamma_max = gamma_max
        self.training_reshape = training_reshape

