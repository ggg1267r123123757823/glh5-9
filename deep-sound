class ClassBalancedFocalLoss(tf.keras.losses.Loss):
    def __init__(self, gamma_init=1.5, gamma_max=3, early_stop_patience=50, reduction=tf.keras.losses.Reduction.NONE):
        super().__init__(reduction=reduction)
        # 基础参数（保留原始配置）
        self.gamma_init = gamma_init
        self.gamma_max = gamma_max
        self.early_stop_patience = early_stop_patience
        self.effective_max_epochs = self.early_stop_patience
        self.current_epoch = 0
        self.current_batch = 0
        
        # 核心配置（完全保留原始逻辑）
        self.valid_targets = ['feeding-chew', 'rumination-chew']
        self.no_event_class = 'no-event'
        self.class_counts = None
        self.class_weights = None
        self.target_encoder = None
        self.valid_indices = []
        
        # 新增：训练/验证状态标记（关键）
        self.is_training = True
        
        # Epoch级统计累加器（新增no-event相关）
        self.epoch_feeding_total = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_feeding_correct = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_feeding_to_rum = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_feeding_to_noevent = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_rumination_total = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_rumination_correct = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_rumination_to_feed = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_rumination_to_noevent = tf.Variable(0, trainable=False, dtype=tf.int32)
        # 新增no-event统计变量
        self.epoch_no_event_total = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_no_event_correct = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_no_event_to_feed = tf.Variable(0, trainable=False, dtype=tf.int32)
        self.epoch_no_event_to_rum = tf.Variable(0, trainable=False, dtype=tf.int32)
        
        # Epoch元信息（保留原始配置）
        self.current_epoch_num = 0
        self.steps_per_epoch = 0
        
        # 初始化logger（保留原始代码）
        self.logger = logging.getLogger(__name__)

    def set_class_counts(self, class_counts, target_encoder):
        """按要求计算权重：no-event=1，其他类=no-event样本数/该类样本数"""
        self.class_counts = class_counts
        self.target_encoder = target_encoder
        self.class_weights = {}
        
        # 步骤1：找到no-event的类别索引和样本数
        no_event_idx = None
        no_event_count = 1  # 兜底，避免除0
        for idx, cnt in class_counts.items():
            label_name = target_encoder.inverse_transform([idx])[0] if self.target_encoder else str(idx)
            if label_name == self.no_event_class:
                no_event_idx = idx
                no_event_count = cnt
                break
        self.logger.info(f"✅ 权重计算基准（no-event）：样本数={no_event_count}，权重固定=1.0")
        
        # 步骤2：计算有效目标类权重（按数量占比逻辑）
        try:
            self.valid_indices = [
                list(target_encoder.classes_).index(label) 
                for label in self.valid_targets 
                if label in target_encoder.classes_
            ]
            self.logger.info(f"✅ 有效目标编码索引：{dict(zip(self.valid_targets, self.valid_indices))}")
        except ValueError as e:
            self.logger.error(f"❌ 编码索引计算失败：{e}")
            self.valid_indices = [0, 2]  # 兜底适配3类编码
        
        
        # 步骤3：赋值权重（核心：按no-event样本数÷类别样本数）
        for idx, cnt in class_counts.items():
            label_name = target_encoder.inverse_transform([idx])[0] if self.target_encoder else str(idx)
            if label_name == self.no_event_class:
                self.class_weights[idx] = 1  # no-event权重固定为1
            elif label_name in self.valid_targets:
                weight = no_event_count / cnt
                # weight = no_event_count / no_event_count
                self.class_weights[idx] = weight
            else:
                self.class_weights[idx] = 1.0  # 其他类默认权重1
        
        self.logger.info(f"✅ 类别权重计算完成（按数量占比）：{self.class_weights}")
