class CEWeightedCrossEntropy(tf.keras.losses.Loss):
    def __init__(self, class_weights=None, target_encoder=None, padding_class=-1, **kwargs):
        super().__init__(reduction=tf.keras.losses.Reduction.NONE, **kwargs)
        self.class_weights = class_weights
        self.target_encoder = target_encoder
        self.padding_class = padding_class
        self._printed = False
        self.logger = logging.getLogger(__name__)

    def set_class_counts(self, class_counts, target_encoder):
        self.target_encoder = target_encoder
        if self.class_weights is None:
            self.class_weights = {cls: 1.0 for cls in class_counts.keys()}
        self.logger.info(f"✅ 【无损失加权 等权重】完成：{self.class_weights}")

    def call(self, y_true, y_pred, sample_weight=None):
        def main_gpu_logic(yt, yp):
            if not self._printed:
                tf.print("\n【4方案加权CE权重】：", output_stream=sys.stderr)
                for cls_idx, w in self.class_weights.items():
                    try:
                        cls_name = self.target_encoder.inverse_transform([cls_idx])[0]
                    except:
                        cls_name = f"class_{cls_idx}"
                    tf.print(f"  {cls_name:18s} → {w:.4f}", output_stream=sys.stderr)
                self._printed = True
            
            # 强制裁剪标签 0~2，彻底杜绝3越界
            yt_safe = tf.clip_by_value(yt, 0, 2)
            valid_mask = tf.cast(tf.not_equal(yt, self.padding_class), tf.float32)
            ce = tf.keras.losses.sparse_categorical_crossentropy(yt_safe, yp, from_logits=True)
            
            if self.class_weights:
                weight_tensor = tf.convert_to_tensor(list(self.class_weights.values()), dtype=tf.float32)
                # ✅ 修复：直接用固定值2（3分类，绝对安全，无len报错）
                cls_weight = tf.gather(weight_tensor, tf.cast(yt_safe, tf.int32))
                ce = ce * cls_weight

            if sample_weight is not None:
                ce = ce * tf.cast(sample_weight, tf.float32)
                
            return ce * valid_mask

        # CPU/副GPU分支，完全同步修复
        def non_main_gpu_logic(yt, yp):
            yt_safe = tf.clip_by_value(yt, 0, 2)
            valid_mask = tf.cast(tf.not_equal(yt, self.padding_class), tf.float32)
            ce = tf.keras.losses.sparse_categorical_crossentropy(yt_safe, yp, from_logits=True)
            
            if self.class_weights:
                weight_tensor = tf.convert_to_tensor(list(self.class_weights.values()), dtype=tf.float32)
                # ✅ 修复：删除len，直接使用安全索引
                cls_weight = tf.gather(weight_tensor, tf.cast(yt_safe, tf.int32))
                ce = ce * cls_weight

            if sample_weight is not None:
                ce = ce * tf.cast(sample_weight, tf.float32)
                
            return ce * valid_mask

        # 分布式逻辑不变
        if tf.distribute.get_replica_context() is not None:
            replica_id = tf.distribute.get_replica_context().replica_id_in_sync_group
            is_non_main_gpu = tf.not_equal(replica_id, 0)
            loss = tf.cond(
                is_non_main_gpu,
                lambda: non_main_gpu_logic(y_true, y_pred),
                lambda: main_gpu_logic(y_true, y_pred)
            )
        else:
            loss = main_gpu_logic(y_true, y_pred)
        return loss
