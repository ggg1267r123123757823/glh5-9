                    ]).numpy())
                    self.resource_logger.log(f"✅ 截断后理论有效步骤数：{val_truncated_valid}（应接近实际统计总数）")
                    if np.any(val_audio_mask):
                        val_audio[val_audio_mask] = (val_audio[val_audio_mask] - self.train_audio_mean) / (self.train_audio_std + 1e-8)
                        # val_audio = np.clip(val_audio, -5.0, 5.0)
                    self.val_audio = val_audio
                    self.resource_logger.log("验证集标准化完成：复用训练集均值/标准差")

                # 样本权重
