                self.val_audio = val_audio
                self.val_y = val_y
                self.val_sample_weights = val_sample_weights
                self.resource_logger.log(f"✅ 验证集补齐完成：原始{total_val_samples}个→补齐后{self.val_audio.shape[0]}个（目标3批）")
