                        valid_labels = truncated_label_seq[valid_mask]
                        val_truncated_fe += np.sum(valid_labels == fe_idx)
                        val_truncated_ru += np.sum(valid_labels == ru_idx)
                        val_truncated_noevent += np.sum(valid_labels == noevent_idx)
                    # 打印截断后+丢失个数
