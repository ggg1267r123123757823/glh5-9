                    self.resource_logger.log(f"  ru原始个数：{val_original_ru}（节点3基准：1144）")
                    self.resource_logger.log(f"  no-event原始个数：{val_original_noevent}（节点3基准：8549）")
                    self.resource_logger.log(f"  原始总有效个数：{val_original_fe + val_original_ru + val_original_noevent}（节点3基准：11289）")

                    # 2. 再统计截断后个数
                    val_truncated_fe = 0
                    val_truncated_ru = 0
                    val_truncated_noevent = 0
                    for label_seq in val_y:
                        truncated_label_seq = label_seq[:self.max_seq_len]
