                            pad_length = self.max_seq_len - seq_len
                            padded = np.pad(label_seq, pad_width=(0, pad_length), mode='constant', constant_values=self.padding_class)
                        else:
                            padded = label_seq[:self.max_seq_len]
                        val_y_padded.append(padded)  # ✅ 循环内，添加所有17个label_seq
                    val_y = np.array(val_y_padded, dtype='int32')  # 形状：(17, 原始序列长度)

                    # 打印验证集原始个数（与节点3对比）
