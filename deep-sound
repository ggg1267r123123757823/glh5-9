                    train_y = np.concatenate([train_y, train_y_pad], axis=0)
                    train_sample_weights = np.concatenate([train_sample_weights, train_weight_pad], axis=0)

            # 初始化训练历史
            history = {
                'loss': [], 'precision': [], 'valid_target_precision': [],
                'val_loss': [], 'val_precision': [], 'val_valid_target_precision': []
            }
            for callback in model_callbacks:
