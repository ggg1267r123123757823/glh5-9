                callback.on_train_begin(logs=history)

            # 开始训练
            补齐后样本数 = train_audio.shape[0] if train_audio is not None else 0
            self.resource_logger.log(f"\n【开始训练】训练集原始样本数: {original_train_samples}, 补齐后: {补齐后样本数}, GPU数量: {gpu_count}")
            self.resource_logger.update_memory_peaks(phase='training')
            self.train_prec_metric = CustomSparseCategoricalPrecision(num_classes=self.output_size, name='train_precision')
            self.train_prec_metric.set_padding_class(self.padding_class)
            # 训练集指标: 添加class_weights存在性判断  # 把全角“：”改成半角“:”
            self.valid_target_precision_metric = ValidTargetPrecision(
                target_encoder=self.target_encoder,
                valid_targets=['feeding-chew', 'rumination-chew', 'no-event'],
