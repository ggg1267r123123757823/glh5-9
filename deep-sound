# 自定义稀疏分类 Macro 召回率（完全兼容你的代码）
class CustomSparseCategoricalRecall(tf.keras.metrics.Metric):
    def __init__(self, num_classes, name='sparse_macro_recall', **kwargs):
        super().__init__(name=name, **kwargs)
        self.num_classes = num_classes
        # 保留标量存储，完全适配你现有 assign_add 代码
        self.true_positives = self.add_weight(name='tp', initializer='zeros', dtype=tf.float32)
        self.false_negatives = self.add_weight(name='fn', initializer='zeros', dtype=tf.float32)
    
    def update_state(self, y_true, y_pred, sample_weight=None):
        y_true = tf.cast(y_true, tf.int32)
        y_pred_argmax = tf.argmax(y_pred, axis=-1, output_type=tf.int32)

        # 保留你原有的 padding 过滤逻辑
        valid_mask = tf.not_equal(y_true, self.padding_class) if hasattr(self, 'padding_class') else tf.ones_like(y_true, dtype=tf.bool)
        valid_mask = tf.cast(valid_mask, tf.float32)
        if sample_weight is not None:
            valid_mask = valid_mask * tf.cast(sample_weight, tf.float32)

        # 🔥 Macro 核心：逐类别计算 TP/FN，标量累加
        total_tp = 0.0
        total_fn = 0.0
        for cls in range(self.num_classes):
            true_mask = tf.cast(tf.equal(y_true, cls), tf.float32) * valid_mask
            pred_mask = tf.cast(tf.equal(y_pred_argmax, cls), tf.float32)
            tp = tf.reduce_sum(true_mask * pred_mask)
            fn = tf.reduce_sum(true_mask * (1 - pred_mask))
            total_tp += tp
            total_fn += fn

        # 标量累加，和你原有代码完全兼容，无形状报错
        self.true_positives.assign_add(total_tp)
        self.false_negatives.assign_add(total_fn)

    def result(self):
        # 🔥 标准 Macro 召回率：等权算术平均
        per_class_recall = tf.math.divide_no_nan(
            self.true_positives / self.num_classes,
            (self.true_positives + self.false_negatives) / self.num_classes
        )
        return per_class_recall

    def reset_state(self):
        self.true_positives.assign(0.0)
        self.false_negatives.assign(0.0)

    def set_padding_class(self, padding_class):
        self.padding_class = padding_class

# 自定义稀疏分类 Macro 精确率（完全兼容你的代码）
class CustomSparseCategoricalPrecision(tf.keras.metrics.Metric):
    def __init__(self, num_classes, name='sparse_macro_precision', **kwargs):
        super().__init__(name=name, **kwargs)
        self.num_classes = num_classes
        # 保留标量存储，完全适配你现有 assign_add 代码
        self.true_positives = self.add_weight(name='tp', initializer='zeros', dtype=tf.float32)
        self.false_positives = self.add_weight(name='fp', initializer='zeros', dtype=tf.float32)
        self.logger = logging.getLogger(__name__)

    def update_state(self, y_true, y_pred, sample_weight=None):
        y_true = tf.cast(y_true, tf.int32)
        y_pred_argmax = tf.argmax(y_pred, axis=-1, output_type=tf.int32)

        # 保留你原有的 padding 过滤逻辑
        valid_mask = tf.not_equal(y_true, self.padding_class) if hasattr(self, 'padding_class') else tf.ones_like(y_true, dtype=tf.bool)
        valid_mask = tf.cast(valid_mask, tf.float32)
        if sample_weight is not None:
            valid_mask = valid_mask * tf.cast(sample_weight, tf.float32)

        # 🔥 Macro 核心：逐类别计算 TP/FP，标量累加
        total_tp = 0.0
        total_fp = 0.0
        for cls in range(self.num_classes):
            true_mask = tf.cast(tf.equal(y_true, cls), tf.float32) * valid_mask
            pred_mask = tf.cast(tf.equal(y_pred_argmax, cls), tf.float32)
            tp = tf.reduce_sum(true_mask * pred_mask)
            fp = tf.reduce_sum((1 - true_mask) * pred_mask * valid_mask)
            total_tp += tp
            total_fp += fp

        # 标量累加，和你原有代码完全兼容，无形状报错
        self.true_positives.assign_add(total_tp)
        self.false_positives.assign_add(total_fp)

    def result(self):
        # 🔥 标准 Macro 精确率：等权算术平均
        per_class_precision = tf.math.divide_no_nan(
            self.true_positives / self.num_classes,
            (self.true_positives + self.false_positives) / self.num_classes
        )
        return per_class_precision

    def reset_state(self):
        self.true_positives.assign(0.0)
        self.false_positives.assign(0.0)

    def set_padding_class(self, padding_class):
        self.padding_class = padding_class
class ValidTargetPrecision(tf.keras.metrics.Metric):
    def __init__(self, target_encoder, valid_targets, class_weights=None, name='valid_target_precision',** kwargs):
        super().__init__(name=name, **kwargs)
        self.target_encoder = target_encoder
        self.valid_targets = valid_targets
        self.class_weights = class_weights or {}  # 新增：接收类别权重，默认空字典
        self.logger = logging.getLogger(__name__)
        self.padding_class = None
        # 编码索引校验（原有逻辑不变）
        self.valid_indices = []
        for label in valid_targets:
            if label not in target_encoder.classes_:
                raise ValueError(f"有效目标{label}不在编码类别中！编码类别：{target_encoder.classes_}")
            self.valid_indices.append(list(target_encoder.classes_).index(label))
        self.logger.info(f"有效目标编码索引：{dict(zip(valid_targets, self.valid_indices))}")
        # 仅保留精确率所需统计量（TP/FP，原有逻辑不变）
        self.tp = self.add_weight(name='valid_tp', initializer='zeros')
        self.fp = self.add_weight(name='valid_fp', initializer='zeros')
    def update_state(self, y_true, y_pred, sample_weight=None, valid_mask=None):
        y_true = tf.cast(y_true, tf.int32)
        y_pred_argmax = tf.argmax(y_pred, axis=-1)
        # 过滤填充数据（原有逻辑不变）
        if valid_mask is None:
            valid_mask = tf.not_equal(y_true, self.padding_class) if hasattr(self, 'padding_class') else tf.ones_like(y_true, dtype=tf.bool)
        valid_mask = tf.cast(valid_mask, tf.bool)
        for idx in self.valid_indices:
            true_mask = tf.logical_and(valid_mask, tf.equal(y_true, idx))
            pred_mask = tf.logical_and(valid_mask, tf.equal(y_pred_argmax, idx))
            # 新增：获取当前类别的权重，无则默认1.0
            class_weight = self.class_weights.get(idx, 1.0)
            # 新增：打印原始TP/FP（未乘权重）和权重值
            tp_raw = tf.reduce_sum(tf.cast(tf.logical_and(true_mask, pred_mask), tf.float32))
            fp_raw = tf.reduce_sum(tf.cast(tf.logical_and(tf.logical_not(true_mask), pred_mask), tf.float32))
            tf.print(f"⚠️  精确率计算监控 - 类别{idx}（{self.target_encoder.inverse_transform([idx])[0]}）：")
            tf.print(f"  原始TP（未乘权重）：{tp_raw.numpy():.0f} | 原始FP（未乘权重）：{fp_raw.numpy():.0f}")
            tf.print(f"  类别权重：{class_weight:.2f} | 乘权重后TP：{tp_raw * class_weight:.0f} | 乘权重后FP：{fp_raw * class_weight:.0f}")

            self.tp.assign_add(tp_raw * class_weight)
            self.fp.assign_add(fp_raw * class_weight)

    def result(self):
        precision = tf.math.divide_no_nan(self.tp, self.tp + self.fp)
        # 新增：打印最终TP/FP和精确率为0的原因
        tp_final = self.tp.numpy()
        fp_final = self.fp.numpy()
        # tf.print(f"\n⚠️  精确率结果监控：")
        # tf.print(f"  累计TP（乘权重后）：{tp_final:.0f} | 累计FP（乘权重后）：{fp_final:.0f}")
        # if tp_final == 0:
        #     tf.print(f"  精确率为0原因：累计TP=0（模型无正确预测）")
        # elif tp_final + fp_final == 0:
        #     tf.print(f"  精确率为0原因：TP+FP=0（无有效预测）")
        # else:
        #     tf.print(f"  精确率为0原因：TP/FP比例异常（TP={tp_final:.0f}, FP={fp_final:.0f}，精确率={precision.numpy():.6f}）")
        return tf.cond(
            tf.math.is_nan(precision),
            true_fn=lambda: tf.constant(0.0, dtype=tf.float32),
            false_fn=lambda: precision
        )

    def reset_state(self):
        self.tp.assign(0.0)
        self.fp.assign(0.0)
