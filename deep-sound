                total_valid_precision = 0.0  # 初始化有效目标累加器
                num_batches = 0
                self.resource_logger.log(f"Epoch {epoch+1} - 开始训练...")

                # 1. 校验前3个批次标签（保留原有逻辑，仅用于数据校验）
                batch_check_count = 0
                for train_batch in distributed_train_dataset:
                    if batch_check_count >= 3:
                        break
                    x_batch, (y_batch, weight_batch) = train_batch
                    # 关键修复：兼容所有TF版本，不直接引用PerReplica类
                    # 修复代码（用tf.convert_to_tensor+numpy()，仅在Eager模式触发）
                    try:
                        local_y_batch = self.strategy.experimental_local_results(y_batch)[0]
                        # 正确：仅Eager模式转numpy，图模式直接返回Tensor（不转）
                        if tf.executing_eagerly():
                            y_batch_np = tf.convert_to_tensor(local_y_batch).numpy()
                        else:
                            y_batch_np = tf.convert_to_tensor(local_y_batch)  # 图模式不转numpy，直接用Tensor
                    except (AttributeError, TypeError):
                        if tf.executing_eagerly() and isinstance(y_batch, tf.Tensor):
                            y_batch_np = tf.convert_to_tensor(y_batch).numpy()
                        else:
                            y_batch_np = tf.convert_to_tensor(y_batch)  # 图模式直接用Tensor
                    # 检查None/NaN（整数类型无需判断NaN）
                    has_none = np.any(y_batch_np is None)
                    if y_batch_np.dtype in [np.int8, np.int16, np.int32, np.int64]:
                        has_nan = False
                    else:
                        has_nan = np.any(np.isnan(y_batch_np)) if not has_none else False
                    # self.resource_logger.log(f"  批次{batch_check_count+1}：y形状={y_batch_np.shape}，类型={y_batch_np.dtype}，含None={has_none}，含NaN={has_nan}")
                    batch_check_count += 1

                # 2. 执行所有批次的训练步骤（每批统计+累加）
                num_batches = 0
                for batch_idx, train_batch in enumerate(distributed_train_dataset):
                    # 核心修复：调用训练集的step方法，传递train_batch（训练集的批次数据）
                    batch_loss, batch_prec, batch_valid_precision, batch_valid_steps = self.distributed_train_step(
                        train_batch, batch_idx, current_epoch=epoch  # 传递训练集批次+当前Epoch
                    )
                    # 累加损失和指标（按有效步骤数加权，确保统计准确）
                    # 训练集：累加总有效损失、总有效样本
                    self.total_train_valid_loss += batch_loss
                    self.total_train_valid_samples += batch_valid_steps
                    total_prec += batch_prec * batch_valid_steps
                    total_valid_precision += batch_valid_precision * batch_valid_steps
                    num_batches += 1
                # 输出训练集所有批总和
                self.print_train_batch_total()

                # 新增：手动触发训练集误判比例汇总输出
                if self.loss_type == 'focal':  # 核心判断：仅Focal损失访问专属属性
                    self.loss_fn.current_batch = self.train_batch_count  # 传递实际训练批数
                    self.loss_fn.steps_per_epoch = self.train_batch_count  # 强制设置steps_per_epoch为训练批数
                    # 调用Loss的汇总输出逻辑（复制ClassBalancedFocalLoss中的输出代码）
                    def safe_ratio(numerator, denominator):
                        return tf.math.divide_no_nan(
                            tf.cast(numerator, tf.float32), 
                            tf.cast(denominator, tf.float32)
                        )
                    f_corr = safe_ratio(self.loss_fn.epoch_feeding_correct, self.loss_fn.epoch_feeding_total)
                    f_to_rum = safe_ratio(self.loss_fn.epoch_feeding_to_rum, self.loss_fn.epoch_feeding_total)
                    f_to_noe = safe_ratio(self.loss_fn.epoch_feeding_to_noevent, self.loss_fn.epoch_feeding_total)
                    r_corr = safe_ratio(self.loss_fn.epoch_rumination_correct, self.loss_fn.epoch_rumination_total)
                    r_to_feed = safe_ratio(self.loss_fn.epoch_rumination_to_feed, self.loss_fn.epoch_rumination_total)
                    r_to_noe = safe_ratio(self.loss_fn.epoch_rumination_to_noevent, self.loss_fn.epoch_rumination_total)
                    n_corr = safe_ratio(self.loss_fn.epoch_no_event_correct, self.loss_fn.epoch_no_event_total)
                    n_to_feed = safe_ratio(self.loss_fn.epoch_no_event_to_feed, self.loss_fn.epoch_no_event_total)
                    n_to_rum = safe_ratio(self.loss_fn.epoch_no_event_to_rum, self.loss_fn.epoch_no_event_total)
                    feeding_total = tf.cast(self.loss_fn.epoch_feeding_total, tf.int32)
                    rumination_total = tf.cast(self.loss_fn.epoch_rumination_total, tf.int32)
                    no_event_total = tf.cast(self.loss_fn.epoch_no_event_total, tf.int32)
                    gamma_tensor = tf.cast(self.loss_fn.gamma_init, tf.float32)
                    self.resource_logger.log(f"\n📌 Epoch {self.loss_fn.current_epoch_num} 训练集误判比例汇总 📌")
                    tf.print(
                        "├─ feeding-chew（总有效样本：", feeding_total, "）| 预测正确：",
                        tf.round(tf.multiply(f_corr, 10000) / 100), "% | 误判为rumination：",
                        tf.round(tf.multiply(f_to_rum, 10000) / 100), "% | 误判为no-event：",
                        tf.round(tf.multiply(f_to_noe, 10000) / 100), "%",
                        output_stream=sys.stderr
                    )
                    tf.print(
                        "├─ rumination-chew（总有效样本：", rumination_total, "）| 预测正确：",
                        tf.round(tf.multiply(r_corr, 10000) / 100), "% | 误判为feeding：",
                        tf.round(tf.multiply(r_to_feed, 10000) / 100), "% | 误判为no-event：",
                        tf.round(tf.multiply(r_to_noe, 10000) / 100), "%",
                        output_stream=sys.stderr
                    )
                    tf.print(
                        "├─ no-event（总有效样本：", no_event_total, "）| 预测正确：",
                        tf.round(tf.multiply(n_corr, 10000) / 100), "% | 误判为feeding：",
                        tf.round(tf.multiply(n_to_feed, 10000) / 100), "% | 误判为rumination：",
                        tf.round(tf.multiply(n_to_rum, 10000) / 100), "%",
                        output_stream=sys.stderr
                    )
                    tf.print(
                        "└─ 本轮gamma值：", tf.round(tf.multiply(gamma_tensor, 100) / 100), "（难样本惩罚强度）\n",
                        output_stream=sys.stderr
                    )
                else:
                    # CE损失跳过误判比例输出，避免访问不存在的属性
                    self.resource_logger.log(f"\n📌 Epoch {epoch+1} 训练集汇总（CE损失）📌")
                    self.resource_logger.log(f"  总批数：{self.train_batch_count} | 总窗口数：{int(self.train_all_total)} | 有效类TP：{total_valid_precision:.0f}")

                # 👇 只改这一行：自动计算正确Loss
                # 正确训练loss：总有效损失 ÷ 总有效样本
                avg_loss = self.total_train_valid_loss / self.total_train_valid_samples if self.total_train_valid_samples > 0 else 0.0
                # 你的precision/recall完全不动（本来就正确）
                # 直接获取正确的Macro精确率、Macro召回率
                avg_prec = self.train_prec_metric.result().numpy()
                avg_recall = self.train_recall_metric.result().numpy()
                avg_valid_precision = self.valid_target_precision_metric.result().numpy()

                # 验证阶段（单独执行，确保val_batch仅在循环内定义）
                avg_val_loss = 0.0
                avg_val_prec = 0.0
                avg_val_valid_precision = 0.0
                total_val_correct = 0.0
                total_val_samples = 0.0
                total_val_valid_precision = 0.0
                val_num_batches = 0
                val_all_y_true = []
                val_all_y_pred = []

                if use_validation and distributed_val_dataset is not None:
                    val_total_loss = 0.0
                    self.resource_logger.log(f"Epoch {epoch+1} - 开始验证...")
                    # 核心修复1：设置Loss为验证状态，不触发训练日志
                    if self.loss_type == 'focal':  # 仅Focal损失执行自定义方法
                        self.loss_fn.set_training_state(is_training=False)
                    # 核心修复2：重置训练集统计变量，避免叠加
                    if self.loss_type == 'focal':  # 只有Focal损失需要重置统计，CE损失跳过
                        self.loss_fn.reset_epoch_stats()  # 重置本轮统计
                    # 核心修复3：提前计算验证集总批数（确保变量定义）
                    val_sample_count = self.val_audio.shape[0] if self.val_audio is not None else 0
                    total_val_batches = (val_sample_count + val_initial_batch - 1) // val_initial_batch
                    self.loss_fn.steps_per_epoch = total_val_batches
                    self.loss_fn.current_batch = 0  # 验证集批次计数器从0开始

                    # ====================== 验证集循环（核心修复：val_batch仅在循环内使用）======================
                    for batch_idx, val_batch in enumerate(distributed_val_dataset):
                        # 调用distributed_val_step时，val_batch已在循环内定义
                        val_loss_batch, val_batch_prec, val_batch_valid_precision, val_total_steps = self.distributed_val_step(
                            val_batch, batch_idx, current_epoch=epoch  # 正确传递val_batch（循环内变量）
                        )
                        # 后续累加逻辑（循环内完成，不依赖外部val_batch）
                        # 验证集：累加总有效损失、总有效样本
                        self.total_val_valid_loss += val_loss_batch
                        self.total_val_valid_samples += val_total_steps
                        total_val_correct += val_batch_prec * val_total_steps
                        total_val_valid_precision += val_batch_valid_precision * val_total_steps
                        total_val_samples += val_total_steps
                        val_num_batches += 1
                        # self.resource_logger.log(f"  验证集批次{batch_idx+1}/{total_val_batches} 完成，累计有效样本：{int(total_val_samples)}")

                        # （保留原有预测结果收集逻辑，全部在循环内完成）
                        x_batch, (y_batch, val_sample_weights) = val_batch
                        local_y_batches = self.strategy.experimental_local_results(y_batch) if 'y_batch' in locals() else []
                        local_x_batches = self.strategy.experimental_local_results(x_batch) if 'x_batch' in locals() else []
                        local_y = local_y_batches[0] if len(local_y_batches) > 0 else None
                        local_x = local_x_batches[0] if len(local_x_batches) > 0 else None
                        if local_y is not None and local_x is not None:
                            local_pred_logits = self.model(local_x, training=False)
                            local_pred_proba = tf.nn.softmax(local_pred_logits).numpy()
                            if self.padding_class is not None and self.padding_class < local_pred_proba.shape[-1]:
                                local_pred_proba[..., self.padding_class] = 0.0
                                valid_classes_mask = np.arange(local_pred_proba.shape[-1]) != self.padding_class
                                valid_sums = local_pred_proba[..., valid_classes_mask].sum(axis=-1, keepdims=True)
                                valid_sums = np.where(valid_sums == 0, 1.0, valid_sums)
                                local_pred_proba[..., valid_classes_mask] /= valid_sums
                            local_pred_argmax = np.argmax(local_pred_proba, axis=-1)
                            local_y_np = local_y.numpy()
                            valid_mask = local_y_np != self.padding_class
                            for seq_true, seq_pred, mask in zip(local_y_np, local_pred_argmax, valid_mask):
                                true_valid = seq_true[mask]
                                pred_valid = seq_pred[mask]
                                pred_valid = pred_valid[pred_valid != self.padding_class]
                                min_len = min(len(true_valid), len(pred_valid))
                                if min_len > 0:
                                    val_all_y_true.extend(true_valid[:min_len])
                                    val_all_y_pred.extend(pred_valid[:min_len])
                    # ====================== 循环结束（val_batch不再被引用）======================

                    # 未跑完批次的警告（保留原有逻辑）
                    if val_num_batches != total_val_batches:
                        self.resource_logger.log(f"❌ 验证集未跑完所有批次！预期{total_val_batches}批，实际{val_num_batches}批")

                    # 关闭窗口日志器（避免内存泄漏）
                    if self.enable_win_log and self.win_logger:
                        for handler in self.win_logger.handlers[:]:
                            handler.close()
                            self.win_logger.removeHandler(handler)
                        self.win_logger = None

                    # 验证集指标计算（循环外无val_batch引用）
                    # 正确验证loss：总有效损失 ÷ 总有效样本
                    avg_val_loss = self.total_val_valid_loss / self.total_val_valid_samples if self.total_val_valid_samples > 0 else 0.0
                    # 直接获取验证集正确的Macro精确率、Macro召回率
                    avg_val_prec = self.val_prec_metric.result().numpy()
                    avg_val_recall = self.val_recall_metric.result().numpy()
                    avg_val_valid_precision = self.val_valid_target_precision_metric.result().numpy()

                # 验证阶段误判统计日志（复用已收集的预测结果，确保比例和为100%）
                if val_num_batches > 0 and len(val_all_y_true) > 0:  # 去掉self.，使用局部变量
                    # 1. 初始化统计变量（含异常值处理）
                    val_feeding_correct = 0
                    val_feeding_to_rum = 0
                    val_feeding_to_noevent = 0
                    val_rumination_correct = 0
                    val_rumination_to_feed = 0
                    val_rumination_to_noevent = 0
                    val_no_event_correct = 0
                    val_no_event_to_feed = 0
                    val_no_event_to_rum = 0
                    # 2. 遍历统计（同源数据：val_all_y_true/pred 与 self.val_all_fe/ru/noevent 来自同一批验证数据）
                    for t, p in zip(val_all_y_true, val_all_y_pred):  # 去掉self.，使用局部变量
                        true_label = self.target_encoder.inverse_transform([t])[0] if t in [0,1,2] else 'other'
                        pred_label = self.target_encoder.inverse_transform([p])[0] if p in [0,1,2] else 'other'
                        

                        if true_label == 'feeding-chew':
                            if pred_label == 'feeding-chew':
                                val_feeding_correct += 1
                            elif pred_label == 'rumination-chew':
                                val_feeding_to_rum += 1
                            elif pred_label == 'no-event':
                                val_feeding_to_noevent += 1
                            else:
                                # 异常值按1:1:1分摊，避免比例缺失
                                val_feeding_correct += 1/3
                                val_feeding_to_rum += 1/3
                                val_feeding_to_noevent += 1/3
                        elif true_label == 'rumination-chew':
                            if pred_label == 'rumination-chew':
                                val_rumination_correct += 1
                            elif pred_label == 'feeding-chew':
                                val_rumination_to_feed += 1
                            elif pred_label == 'no-event':
                                val_rumination_to_noevent += 1
                            else:
                                val_rumination_correct += 1/3
                                val_rumination_to_feed += 1/3
                                val_rumination_to_noevent += 1/3
                        elif true_label == 'no-event':
                            if pred_label == 'no-event':
                                val_no_event_correct += 1
                            elif pred_label == 'feeding-chew':
                                val_no_event_to_feed += 1
                            elif pred_label == 'rumination-chew':
                                val_no_event_to_rum += 1
                            else:
                                val_no_event_correct += 1/3
                                val_no_event_to_feed += 1/3
                                val_no_event_to_rum += 1/3

                    # 3. 基数统一：直接用批次累计的真实总数（与分子统计同源，无重复设置）
                    val_feeding_total = self.val_all_fe if self.val_all_fe > 0 else 1
                    val_rumination_total = self.val_all_ru if self.val_all_ru > 0 else 1
                    val_no_event_total = self.val_all_noevent if self.val_all_noevent > 0 else 1

                    # 4. 比例兜底修正（强制每类和为100%）
                    def adjust_ratio(correct, err1, err2):
                        total = correct + err1 + err2
                        if total == 0:
                            return 0, 0, 0
                        # 按真实比例计算，不强制补全，允许和≠100%（四舍五入导致）
                        correct = round((correct / total) * 100)
                        err1 = round((err1 / total) * 100)
                        err2 = round((err2 / total) * 100)
                        return correct, err1, err2

                    # 应用修正
                    fe_corr, fe_rum, fe_noe = adjust_ratio(val_feeding_correct, val_feeding_to_rum, val_feeding_to_noevent)
                    ru_corr, ru_feed, ru_noe = adjust_ratio(val_rumination_correct, val_rumination_to_feed, val_rumination_to_noevent)
                    noe_corr, noe_feed, noe_rum = adjust_ratio(val_no_event_correct, val_no_event_to_feed, val_no_event_to_rum)

                    # 5. 输出与训练集格式一致的日志
                    self.resource_logger.log(f"\n📌 Epoch {epoch+1} 验证集误判比例汇总 📌")
                    tf.print(
                        "├─ feeding-chew（总有效样本：", val_feeding_total, "）| 预测正确：",
                        fe_corr, "% | 误判为rumination：", fe_rum, "% | 误判为no-event：", fe_noe, "%",
                        output_stream=sys.stderr
                    )
                    tf.print(
                        "├─ rumination-chew（总有效样本：", val_rumination_total, "）| 预测正确：",
                        ru_corr, "% | 误判为feeding：", ru_feed, "% | 误判为no-event：", ru_noe, "%",
                        output_stream=sys.stderr
                    )
                    tf.print(
                        "├─ no-event（总有效样本：", val_no_event_total, "）| 预测正确：",
                        noe_corr, "% | 误判为feeding：", noe_feed, "% | 误判为rumination：", noe_rum, "%",
                        output_stream=sys.stderr
                    )
                    # 计算当前验证集gamma值（仅Focal损失需要，CE损失跳过）
                    if self.loss_type == 'focal':
                        current_gamma = self.loss_fn.gamma_init + (self.loss_fn.gamma_max - self.loss_fn.gamma_init) * min(
                            self.loss_fn.current_epoch_num / self.loss_fn.effective_max_epochs, 1.0
                        )
                        # 可选：保留gamma值输出（仅Focal损失显示）
                        tf.print(
                            "└─ 验证集gamma值：", tf.round(tf.multiply(current_gamma, 100) / 100), "（难样本惩罚强度）\n",
                            output_stream=sys.stderr
                        )
                    

                # 更新训练历史
                history['loss'].append(avg_loss)
                history['precision'].append(avg_prec)
                history['valid_target_precision'].append(avg_valid_precision)
                history['val_loss'].append(avg_val_loss)
                history['val_precision'].append(avg_val_prec)
                history['val_valid_target_precision'].append(avg_val_valid_precision)

                # 日志输出（统一整合所有指标）
                logs = {
                    'loss': avg_loss,
                    'precision': avg_prec,
                    'valid_target_precision': avg_valid_precision,
                    'val_loss': avg_val_loss,
                    'val_precision': avg_val_prec,
                    'val_valid_target_precision': avg_val_valid_precision
                }
                avg_recall = self.train_recall_metric.result().numpy()
                log_msg = f"Epoch {epoch+1}/{self.n_epochs} - loss: {avg_loss:.4f} - precision: {avg_prec:.4f} - recall: {avg_recall:.4f} "
                if use_validation:
                    avg_val_recall = self.val_recall_metric.result().numpy()
                    log_msg += f" - val_loss: {avg_val_loss:.4f} - val_precision: {avg_val_prec:.4f} - val_recall: {avg_val_recall:.4f}"
                self.resource_logger.log(log_msg)

                # 触发回调
                for callback in model_callbacks:
                    callback.on_epoch_end(epoch, logs=logs)

                # 内存清理日志
                mem_after_epoch = process.memory_info().rss / (1024**3)
                memory_logger.log_epoch_mem(epoch, mem_before_epoch, mem_after_epoch)

                # 早停检查
                early_stopping_triggered = False
                for cb in model_callbacks:
                    if isinstance(cb, EarlyStopping) and cb.stopped_epoch == epoch:
                        if epoch >= 2 and cb.wait >= cb.patience:
                            early_stopping_triggered = True
                            break
                if early_stopping_triggered:
                    self.resource_logger.log(f"早停触发，在第{epoch+1}轮停止训练")
                    break

            # 训练总结
            training_time = time.time() - training_start_time
            training_summary: Dict[str, str] = {
                "总训练轮次上限": str(self.n_epochs),
                "实际训练轮次": str(len(history['loss'])),
                "训练集原始样本数": str(original_train_samples),
                "训练集补齐后样本数": str(train_audio.shape[0]),
                "训练集填充样本数": str(train_audio.shape[0] - original_train_samples),
                "训练集总有效时间步": str(self.train_total_valid_steps),
                "最终训练loss": f"{history['loss'][-1]:.4f}" if history['loss'] else "N/A",
                "最终训练准确率": f"{history['precision'][-1]:.4f}" if history['precision'] else "N/A/A",
                "总训练时间": f"{training_time:.2f}秒"
            }
            if use_validation and history['val_loss']:
                training_summary["验证集原始样本数"] = str(total_val_samples)
                training_summary["验证集补齐后样本数"] = str(val_audio.shape[0]) if val_audio is not None else "0"
                training_summary["验证集填充样本数"] = str(val_audio.shape[0] - total_val_samples) if val_audio is not None else "0"
                training_summary["验证集总有效时间步"] = str(self.val_total_valid_steps)
                training_summary["最终验证loss"] = f"{history['val_loss'][-1]:.4f}"
                training_summary["最终验证准确率"] = f"{history['val_precision'][-1]:.4f}" if history['val_precision'] else "N/A"

            self.resource_logger.record_training_summary(training_summary)
            self.resource_logger.record_memory_summary()

        except Exception as e:
            self.resource_logger.log(f"训练过程出错: {str(e)}")
            traceback.print_exc()
            raise

        finally:
            self.resource_logger.save_log()
    

    def predict(self, X: Union[List[np.ndarray], np.ndarray], aggregate: bool = False) -> Union[List[np.ndarray], np.ndarray]:
        try:
            if self.max_seq_len is None:
                raise RuntimeError("请先训练模型或加载完整模型参数（含max_seq_len）")
            audio_X = X
            pred_detector = NaNDetector(verbose=True)
            self.resource_logger.log("\n===== 开始预测 =====")
            self.resource_logger.update_memory_peaks(phase='training')

            # 核心修复：降维处理（去掉多余的batch维度和通道维度）
            with tf.device('/CPU:0'):
                # 1. 把输入转为numpy数组（防止是列表）
                if isinstance(audio_X, list):
                    audio_X = np.array(audio_X, dtype='float32')
                # 2. 去掉维度为1的轴（4维→2维：(1,445,820,1) → (445,820)）
                audio_X = np.squeeze(audio_X)
                # 3. 确保最终是2维（序列长度, 特征维度）
                if audio_X.ndim != 2:
                    raise ValueError(f"输入维度异常！预期2维，实际{audio_X.ndim}维，形状{audio_X.shape}")

            # 处理音频数据（修复长度记录：填充前记录原始长度）
            with tf.device('/CPU:0'):
                audio_array = []
                pred_original_lengths = []  # 记录填充/裁剪前的原始长度
                pred_final_keep_lengths = []  # 记录最终要保留的长度
                for i, sample in enumerate([audio_X]):  # 遍历单个2维样本
                    if isinstance(sample, list):
                        sample = np.array(sample, dtype='float32')
                    elif not isinstance(sample, np.ndarray):
                        raise TypeError(f"音频样本{i}仅支持list或np.ndarray，实际类型：{type(sample)}")
                    original_len = sample.shape[0]  # 现在是2维，sample.shape[0]是序列长度
                    pred_original_lengths.append(original_len)
                    # 原有维度处理逻辑不变
                    sample = sample.astype('float32')
                    seq_len, feat_dim = sample.shape  # 正常拆包：序列长度, 特征维度
                    if feat_dim != self.input_size:
                        sample = sample[:, :self.input_size] if feat_dim > self.input_size else np.pad(sample, ((0,0), (0, self.input_size-feat_dim)), mode='constant')

                    # 确定最终保留长度（不强制修改，仅适配场景）
                    if seq_len < self.max_seq_len:
                        sample = np.pad(sample, ((0, self.max_seq_len-seq_len), (0,0)), mode='constant', constant_values=-1.0)
                        final_keep_len = original_len
                    else:
                        sample = sample[:self.max_seq_len, :]
                        final_keep_len = self.max_seq_len

                    pred_final_keep_lengths.append(final_keep_len)
                    audio_array.append(sample)
                    if i % 10 == 0:
                        self.resource_logger.update_memory_peaks(phase='training')
                audio_X = audio_array

            # 音频维度统一
            with tf.device('/CPU:0'):
                audio_X = [
                    np.expand_dims(s, axis=-1) if s.ndim == 1 
                    else np.squeeze(s, axis=-1) if (s.ndim == 3 and s.shape[-1] == 1)
                    else s.reshape(s.shape[0], -1) if s.ndim > 2  # 新增：4维样本自动转为2维
                    else s 
                    for s in audio_X
                ]

            # 填充/截断
            with tf.device('/CPU:0'):
                target_len = self.max_seq_len
                audio_padded = []
                for i, s in enumerate(audio_X):
                    if s.ndim != 2:
                        raise ValueError(f"音频样本{i}需2维，实际形状：{s.shape}")
                    seq_len, feat_dim = s.shape
                    if feat_dim != self.input_size:
                        s = s[:, :self.input_size] if feat_dim > self.input_size else np.pad(s, ((0,0), (0, self.input_size-feat_dim)), mode='constant')
                    if seq_len < target_len:
                        s = np.pad(s, ((0, target_len-seq_len), (0,0)), mode='constant', constant_values=-1.0)
                    else:
                        s = s[:target_len, :]
                    audio_padded.append(s)
                if len(set([s.shape for s in audio_padded])) != 1:
                    raise ValueError("音频样本填充后形状不一致")

                # 转换为数组并添加通道
                audio_X = np.array(audio_padded, dtype='float32')
                if audio_X.ndim == 3:
                    audio_X = np.expand_dims(audio_X, axis=-1)

                # 标准化（复用训练集参数）
                if self.feature_scaling:
                    if self.train_audio_mean is None or self.train_audio_std is None:
                        raise RuntimeError("请先训练模型，确保训练集的均值/标准差已保存")
                    audio_mask = (audio_X != -1.0) & (audio_X <= 1000) & (audio_X >= -1000)
                    if np.any(audio_mask):
                        audio_X[audio_mask] = (audio_X[audio_mask] - self.train_audio_mean) / (self.train_audio_std + 1e-8)

            # 清理临时变量
            # del audio_padded
            # gc.collect()
            self.resource_logger.update_memory_peaks(phase='training')

            # 多GPU批次补齐
            with tf.device('/CPU:0'):
                gpu_count = self.strategy.num_replicas_in_sync if (self.strategy and hasattr(self.strategy, 'num_replicas_in_sync')) else 1
                single_gpu_batch = self.batch_size
                min_replica_batch = single_gpu_batch * gpu_count
                total_pred_samples = audio_X.shape[0]
                pad_samples = (min_replica_batch - (total_pred_samples % min_replica_batch)) % min_replica_batch
                if pad_samples > 0:
                    audio_pad = np.full((pad_samples,) + audio_X.shape[1:], -1.0, dtype='float32')
                    audio_X = np.concatenate([audio_X, audio_pad], axis=0)

            # 模型预测
            assert self.model is not None, "模型未初始化，请先训练或加载权重"
            with self.strategy.scope() if self.strategy else tf.device('/CPU:0'):
                y_pred_proba = self.model.predict(audio_X, verbose=1)
            y_pred_proba = y_pred_proba[:total_pred_samples]

            # 处理预测结果
            with tf.device('/CPU:0'):
                y_pred_proba = tf.nn.softmax(y_pred_proba).numpy()
                padding_class = 3  # 从模型属性中读取，无需硬编码
                if padding_class is not None and padding_class < y_pred_proba.shape[-1]:
                    # 1. 将填充类的概率设为0（不参与预测）
                    y_pred_proba[..., padding_class] = 0.0
                    # 2. 仅对有效类（排除padding_class）归一化
                    valid_classes_mask = np.arange(y_pred_proba.shape[-1]) != padding_class
                    valid_sums = y_pred_proba[..., valid_classes_mask].sum(axis=-1, keepdims=True)
                    # 避免除以零（极端情况所有有效类概率为0时，设为均匀分布）
                    valid_sums = np.where(valid_sums == 0, 1.0, valid_sums)
                    # 3. 有效类概率归一化（保证和为1）
                    y_pred_proba[..., valid_classes_mask] = y_pred_proba[..., valid_classes_mask] / valid_sums
                y_pred = y_pred_proba.argmax(axis=-1)

                # 按最终保留长度裁剪（精准去掉填充部分）
                trimmed_preds = []
                for i in range(len(y_pred)):
                    keep_len = pred_final_keep_lengths[i]
                    trimmed = y_pred[i, :min(keep_len, y_pred.shape[1])]
                    trimmed_preds.append(trimmed)

                # 聚合结果
                if aggregate:
                    aggregated = []
                    for seq in trimmed_preds:
                        if len(seq) == 0:
                            aggregated.append(0)
                        else:
                            aggregated.append(np.argmax(np.bincount(seq)))
                        result = np.array(aggregated, dtype=int)
                    self.resource_logger.log(f"预测完成，聚合结果形状：{result.shape}")
                    # del y_pred_proba, y_pred, trimmed_preds
                    gc.collect()
                    return result
                else:
                    flat_preds = np.concatenate(trimmed_preds) if trimmed_preds else np.array([])
                    self.resource_logger.log(f"预测完成，窗口级结果长度：{len(flat_preds)}")
                    # if 'audio_pad' in locals():
                    #     del audio_pad
                    # del y_pred_proba, y_pred, trimmed_preds
                    # gc.collect()
                    return flat_preds

        except Exception as e:
            self.resource_logger.log(f"预测出错：{str(e)}")
            traceback.print_exc()
            raise

    # 预测类别概率（单输入，仅音频数据）
    def predict_proba(self, X: Union[List[np.ndarray], np.ndarray]) -> Union[List[np.ndarray], np.ndarray]:
        """预测类别概率，返回每个样本各时间步的类别概率分布"""
        try:
            if self.max_seq_len is None:
                raise RuntimeError("请先训练模型或加载完整模型参数（含max_seq_len）")
            audio_X = X
            pred_detector = NaNDetector(verbose=True)
            self.resource_logger.log("\n===== 开始预测概率 =====")
            self.resource_logger.update_memory_peaks(phase='training')

            # 处理音频数据
            with tf.device('/CPU:0'):
                audio_array = []
                pred_original_lengths = []
                for i, sample in enumerate(audio_X):
                    if isinstance(sample, list):
                        sample = np.array(sample, dtype='float32')
                    elif not isinstance(sample, np.ndarray):
                        raise TypeError(f"音频样本{i}仅支持list或np.ndarray，实际类型：{type(sample)}")
                    sample = sample.astype('float32')
                    audio_array.append(sample)
                    pred_original_lengths.append(sample.shape[0])
                    if i % 10 == 0:
                        self.resource_logger.update_memory_peaks(phase='training')
                audio_X = audio_array

            # 音频维度统一
            with tf.device('/CPU:0'):
                audio_X = [
                    np.expand_dims(s, axis=-1) if s.ndim == 1 
                    else np.squeeze(s, axis=-1) if (s.ndim == 3 and s.shape[-1] == 1)
                    else s.reshape(s.shape[0], -1) if s.ndim > 2  # 新增：4维样本自动转为2维
                    else s 
                    for s in audio_X
                ]

            # 填充/截断至目标序列长度
            with tf.device('/CPU:0'):
                target_len = self.max_seq_len
                audio_padded = []
                for i, s in enumerate(audio_X):
                    if s.ndim != 2:
                        raise ValueError(f"音频样本{i}需2维，实际形状：{s.shape}")
                    seq_len, feat_dim = s.shape
                    if feat_dim != self.input_size:
                        s = s[:, :self.input_size] if feat_dim > self.input_size else np.pad(s, ((0,0), (0, self.input_size-feat_dim)), mode='constant')
                    if seq_len < target_len:
                        s = np.pad(s, ((0, target_len-seq_len), (0,0)), mode='constant', constant_values=-1.0)
                    else:
                        s = s[:target_len, :]
                    audio_padded.append(s)
                if len(set([s.shape for s in audio_padded])) != 1:
                    raise ValueError("音频样本填充后形状不一致，请检查输入数据")

                # 转换为数组并添加通道维度
                audio_X = np.array(audio_padded, dtype='float32')
                if audio_X.ndim == 3:
                    audio_X = np.expand_dims(audio_X, axis=-1)

                # 特征标准化（复用训练集参数）
                if self.feature_scaling:
                    if self.train_audio_mean is None or self.train_audio_std is None:
                        raise RuntimeError("请先训练模型，确保训练集的均值/标准差已保存")
                    audio_mask = (audio_X != -1.0) & (audio_X <= 1000) & (audio_X >= -1000)
                    if np.any(audio_mask):
                        audio_X[audio_mask] = (audio_X[audio_mask] - self.train_audio_mean) / (self.train_audio_std + 1e-8)

            # 清理临时变量
            # del audio_padded
            # gc.collect()
            self.resource_logger.update_memory_peaks(phase='training')

            # 多GPU样本批次补齐
            with tf.device('/CPU:0'):
                gpu_count = self.strategy.num_replicas_in_sync if (self.strategy and hasattr(self.strategy, 'num_replicas_in_sync')) else 1
                single_gpu_batch = self.batch_size
                min_replica_batch = single_gpu_batch * gpu_count
                total_pred_samples = audio_X.shape[0]
                pad_samples = (min_replica_batch - (total_pred_samples % min_replica_batch)) % min_replica_batch
                if pad_samples > 0:
                    audio_pad = np.full((pad_samples,) + audio_X.shape[1:], -1.0, dtype='float32')
                    audio_X = np.concatenate([audio_X, audio_pad], axis=0)

            # 模型预测概率（输出logits后手动softmax）
            assert self.model is not None, "模型未初始化，请先训练或加载权重"
            with self.strategy.scope() if self.strategy else tf.device('/CPU:0'):
                y_pred_logits = self.model.predict(audio_X, verbose=0)
                y_pred_proba = tf.nn.softmax(y_pred_logits).numpy()

            # 截断填充的无效样本结果
            y_pred_proba = y_pred_proba[:total_pred_samples]

            # 按原始长度裁剪概率结果
            with tf.device('/CPU:0'):
                padding_class = 3  # 从模型属性中读取，无需硬编码
                if padding_class is not None and padding_class < y_pred_proba.shape[-1]:
                    # 1. 将填充类的概率设为0（不参与预测）
                    y_pred_proba[..., padding_class] = 0.0
                    # 2. 仅对有效类（排除padding_class）归一化
                    valid_classes_mask = np.arange(y_pred_proba.shape[-1]) != padding_class
                    valid_sums = y_pred_proba[..., valid_classes_mask].sum(axis=-1, keepdims=True)
                    # 避免除以零（极端情况所有有效类概率为0时，设为均匀分布）
                    valid_sums = np.where(valid_sums == 0, 1.0, valid_sums)
                    # 3. 有效类概率归一化（保证和为1）
                    y_pred_proba[..., valid_classes_mask] = y_pred_proba[..., valid_classes_mask] / valid_sums
                trimmed_probs = []
                for i in range(len(y_pred_proba)):
                    real_len = pred_original_lengths[i]
                    trimmed = y_pred_proba[i, :min(real_len, y_pred_proba.shape[1]), :]
                    trimmed_probs.append(trimmed)

            # 清理变量
            # del y_pred_logits, y_pred_proba
            # if 'audio_pad' in locals():
            #     del audio_pad
            # gc.collect()
            self.resource_logger.log(f"预测概率完成，裁剪后结果数量：{len(trimmed_probs)}")
            return trimmed_probs if len(trimmed_probs) > 1 else trimmed_probs[0]

        except Exception as e:
            self.resource_logger.log(f"预测概率出错：{str(e)}")
            traceback.print_exc()
            raise

    def _get_samples_weights(self, y):
        """生成样本权重（修复变量未初始化问题）+ 打印权重日志"""
        # 第一步：强制初始化sample_weights（默认全1，确保变量存在）
        if isinstance(y, list):
            sample_weights = []
            for seq in y:
                seq_weights = np.ones_like(seq, dtype='float32')
                sample_weights.append(seq_weights)
        else:
            sample_weights = np.ones_like(y, dtype='float32')

        # ===================== 【打印1：初始权重】 =====================
        print("\n===== 样本权重初始状态 =====")
        print(f"默认权重全为: 1.0")

        # 第二步：根据class_weights替换对应类别的权重
        if hasattr(self, 'loss_fn') and hasattr(self.loss_fn, 'class_weights') and self.loss_fn.class_weights:
            class_weights = self.loss_fn.class_weights
            # ===================== 【打印2：类别权重】 =====================
            print(f"\n===== 加载类别权重 =====")
            print(f"损失函数class_weights: {class_weights}")

            for cls_idx, weight in class_weights.items():
                if isinstance(sample_weights, list):
                    for seq_idx in range(len(sample_weights)):
                        cls_mask = y[seq_idx] == cls_idx
                        sample_weights[seq_idx][cls_mask] = weight
                else:
                    cls_mask = y == cls_idx
                    sample_weights[cls_mask] = weight
        else:
            print(f"\n===== 未检测到class_weights，权重保持默认1.0 =====")

        # 第三步：兜底校验
        if sample_weights is None or (isinstance(sample_weights, (list, np.ndarray)) and len(sample_weights) == 0):
            if isinstance(y, list):
                sample_weights = [np.ones_like(seq, dtype='float32') for seq in y]
            else:
                sample_weights = np.ones_like(y, dtype='float32')

        # ===================== 【打印3：最终权重统计】 =====================
        print(f"\n===== 最终样本权重 =====")
        if isinstance(sample_weights, np.ndarray):
            print(f"权重形状: {sample_weights.shape}")
            print(f"权重最大值: {np.max(sample_weights):.4f}")
            print(f"权重最小值: {np.min(sample_weights):.4f}")
            print(f"权重是否全为1: {np.all(sample_weights == 1.0)}")
        else:
            print(f"权重为列表格式，总样本数: {len(sample_weights)}")
            print(f"所有权重均为1: {all(np.all(sw == 1.0) for sw in sample_weights)}")
        print("="*50)

        return sample_weights

    

