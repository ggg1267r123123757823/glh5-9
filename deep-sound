            # 🔥 官方原版余弦衰减 + 内置打印（不依赖任何外部变量，零报错）
            def cosine_schedule(epoch):
                initial_lr = self.learning_rate
                T_max = self.n_epochs // 2
                eta_min = 1e-6

                # 核心公式（无阉割，和官方完全一致）
