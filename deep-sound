                    train_sample_weights = self._get_samples_weights(train_y)
                    train_sample_weights = np.clip(train_sample_weights, 0.0, 5.0)
                    val_sample_weights = self._get_samples_weights(val_y)
                else:
                    print(f"[INFO] ❌ 已关闭 样本加权（所有样本权重=1）")
                    train_sample_weights = np.ones_like(train_y, dtype='float32')
                    val_sample_weights = np.ones_like(val_y, dtype='float32')
                # 新增：赋值给实例属性，确保分布式验证能访问到
                self.val_sample_weights = val_sample_weights
